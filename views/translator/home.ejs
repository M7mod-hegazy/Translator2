      var needsSpace = after.length > 0 && after[0] !== ' ' ? ' ' : '';
      srcText.value = before + term + needsSpace + after;
      var newPos = wordInfo.start + term.length + needsSpace.length;
      srcText.setSelectionRange(newPos, newPos);
