    function autoSave() {
      // Skip auto-save entirely for guests
      if (!isLoggedIn) return;
      
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(function() {
        var text = srcText.value.trim();
        if (!text) return;
        var translations = {};
        for (var code in lastTranslations) { var t = lastTranslations[code].full_translation; if (t) translations[code] = t; }
        if (!Object.keys(translations).length) return;
        
        // Collect glossary words used in this session
        var glossaryWords = [];
        if (lastGlossarySegments && lastGlossarySegments.length) {
          lastGlossarySegments.forEach(function(seg) {
            if (chipStates[seg.term_id] !== false) {
              glossaryWords.push({
                term_id: seg.term_id,
                source: seg.source,
                term_en: seg.term_en || '',
                term_ar: seg.term_ar || '',
                term_es: seg.term_es || ''
              });
            }
          });
        }
        
        var payload = { source_text: text, source_lang: currentSourceLang, translations: translations, category_id: catSelect.value || null, glossary_words: glossaryWords };
        if (currentSessionId) payload.session_id = currentSessionId;
        
        console.log('[DEBUG][autoSave] ──── AUTO SAVE ────');
        console.log('[DEBUG][autoSave] Payload:', JSON.stringify({ text: text.substring(0, 30), langs: Object.keys(translations), session_id: currentSessionId || 'NEW', glossaryWords: glossaryWords.length }));
        
        fetch('/api/save-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify(payload)
        }).then(function(response) {
          return response.json().then(function(data) {
            console.log('[DEBUG][autoSave] Response status:', response.status, 'data:', JSON.stringify(data));
            
            if (response.status === 401 || data.requireLogin) {
              // Don't show modal on auto-save, just silently skip
              console.log('[DEBUG][autoSave] Login required — auto-save skipped silently');
              return;
            }
            
            if (!data.success) {
              console.warn('[DEBUG][autoSave] Save failed:', data.error);
              return;
            }
            
            if (data.session_id) {
              currentSessionId = data.session_id;
              console.log('[DEBUG][autoSave] ✓ Session saved:', currentSessionId);
            }
            autoSaveDot.style.display = 'inline-block';
            setTimeout(function() { autoSaveDot.style.display = 'none'; }, 2000);
          });
        }).catch(function(err) {
          console.error('[DEBUG][autoSave] Network error:', err.message);
        });
      }, 1500);
    }

