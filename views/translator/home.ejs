    // Ghost text autocomplete
    var wordHistory = new Set();
    var bigramMap = Object.create(null);

    function collectWords(text) {
      if (!text || typeof text !== 'string') return;
      var words = text.split(/[\s\n]+/);
      var prev = null;
      for (var i = 0; i < words.length; i++) {
        var raw = words[i];
        if (!raw) continue;
        var w = raw.replace(/[^\w\u0600-\u06FF\u00C0-\u024F'-]/g, '');
        if (w && w.length >= 2) {
          wordHistory.add(w);
          if (prev) {
            var key = prev.toLowerCase();
            if (!bigramMap[key]) bigramMap[key] = Object.create(null);
            var nk = w.toLowerCase();
            bigramMap[key][nk] = (bigramMap[key][nk] || 0) + 1;
          }
          prev = w;
        }
      }
    }

    function updateGhostText() {
      var text = srcText.value || '';
      var pos = srcText.selectionStart;
      collectWords(text);
      if (pos === 0) { ghostOverlay.innerHTML = ''; return; }
      var start = pos;
      while (start > 0 && text[start - 1] && /\S/.test(text[start - 1])) start--;
      var partial = text.substring(start, pos);
      var prevEnd = start;
      while (prevEnd > 0 && text[prevEnd - 1] && /\s/.test(text[prevEnd - 1])) prevEnd--;
      var prevStart = prevEnd;
      while (prevStart > 0 && text[prevStart - 1] && /\S/.test(text[prevStart - 1])) prevStart--;
      var prevWord = text.substring(prevStart, prevEnd);
      var atWordStart = pos > 0 && text[pos - 1] === ' ';
      var match = findGhostCompletion(atWordStart ? '' : partial, prevWord);
      if (match && match.toLowerCase().indexOf((partial || '').toLowerCase()) === 0 && match.length > (partial || '').length) {
        var remainder = match.substring((partial || '').length);
        currentGhostSuggestion = remainder;
        var before = escapeHtml(text.substring(0, pos));
        ghostOverlay.innerHTML = before + '<span class="ghost-hint">' + escapeHtml(remainder) + '</span>';
      } else {
        currentGhostSuggestion = '';
        ghostOverlay.innerHTML = '';
      }
    }

    function findGhostCompletion(partial, prevWord) {
      if (!partial || partial.length < 1) return '';
      var lower = partial.toLowerCase();
      var bestMatch = '';
      var bestLen = Infinity;
      var srcField = 'term_' + currentSourceLang;
      for (var i = 0; i < allTermObjects.length; i++) {
        var val = allTermObjects[i][srcField] || '';
        if (val.toLowerCase().indexOf(lower) === 0 && val.length > partial.length && val.length < bestLen) {
          bestMatch = val;
          bestLen = val.length;
        }
      }
      if (bestMatch) return bestMatch;
      wordHistory.forEach(function(w) {
        if (w.toLowerCase().indexOf(lower) === 0 && w.length > partial.length && w.length < bestLen) {
          bestMatch = w;
          bestLen = w.length;
        }
      });
      return bestMatch;
    }

    // Glossary autocomplete dropdown
    function getWordAtCursor() {
      var pos = srcText.selectionStart;
      var text = srcText.value;
      if (!text || pos === 0) return { word: '', start: 0, end: 0 };
      var start = pos;
      while (start > 0 && /\S/.test(text[start - 1])) start--;
      var end = pos;
      return { word: text.substring(start, end), start: start, end: end };
    }

    function showAcDropdown(matches, wordInfo) {
      acDropdown.style.display = 'none';
      acMatches = [];
      acActiveIdx = -1;
    }

    function acSelect(idx) {
      var match = acMatches[idx];
      if (!match) return;
      var wordInfo = getWordAtCursor();
      var srcField = 'term_' + currentSourceLang;
      var replacement = match[srcField] || match.term_en || '';
      if (!replacement) return;
      var before = srcText.value.substring(0, wordInfo.start);
      var after = srcText.value.substring(wordInfo.end);
      var needsSpace = after.length > 0 && after[0] !== ' ' ? ' ' : '';
      srcText.value = before + replacement + needsSpace + after;
      var newPos = wordInfo.start + replacement.length + needsSpace.length;
      srcText.setSelectionRange(newPos, newPos);
      srcText.focus();
      acDropdown.style.display = 'none';
      acMatches = [];
      acActiveIdx = -1;
      srcText.dispatchEvent(new Event('input'));
    }

    srcText.addEventListener('keydown', function(e) {
      if (e.key === 'Tab' && currentGhostSuggestion && acDropdown.style.display === 'none') {
        e.preventDefault();
        var pos = srcText.selectionStart;
        var before = srcText.value.substring(0, pos);
        var after = srcText.value.substring(pos);
        srcText.value = before + currentGhostSuggestion + after;
        var newPos = pos + currentGhostSuggestion.length;
        srcText.setSelectionRange(newPos, newPos);
        currentGhostSuggestion = '';
        ghostOverlay.innerHTML = '';
        srcText.dispatchEvent(new Event('input'));
        return;
      }
      if (e.key === 'Escape') {
        acDropdown.style.display = 'none';
        acMatches = [];
        acActiveIdx = -1;
      }
    });

    function updateAcHighlight() {
      var rows = acDropdown.querySelectorAll('.ac-row');
      for (var i = 0; i < rows.length; i++) {
        rows[i].classList.toggle('is-active', i === acActiveIdx);
      }
      if (rows[acActiveIdx]) rows[acActiveIdx].scrollIntoView({ block: 'nearest' });
    }

    // Input listener for autocomplete
