<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="ORBIS — Professional Translation Memory and CAT Tool">
  <title>Translate — ORBIS</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <!-- Design System -->
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/mobile.css">
  <link rel="stylesheet" href="/css/translate.css">
  <style>
    /* Lucide SVG global sizing */
    .lucide, svg.lucide { width: 16px !important; height: 16px !important; flex-shrink: 0; vertical-align: middle; }
    .btn .lucide, .btn svg.lucide { width: 14px !important; height: 14px !important; }
    .btn-sm .lucide, .btn-sm svg.lucide { width: 13px !important; height: 13px !important; }
    .app-sidebar__icon, .app-sidebar__icon svg, .app-sidebar .app-sidebar__icon-wrap svg { width: 20px !important; height: 20px !important; }
    .app-sidebar .app-sidebar__icon-wrap svg { stroke: currentColor; }
  </style>
</head>

<body>
  <!-- Toast Container -->
  <div id="toast-container" class="toast-container"></div>

  <%- include('../partials/home-mobile-header.ejs', { user: typeof user !== 'undefined' ? user : null }) %>

  <!-- Sidebar outside app-shell so fixed position is viewport-relative on mobile -->
  <%- include('../partials/sidebar.ejs', { activeTab: 'translate', user: user }) %>

  <div class="app-shell">
    <!-- Main Content -->
    <main class="main-content">
      <header class="top-nav">
        <div class="top-nav__left">
          <h1 class="top-nav__page-title">Translate</h1>
        </div>
        <div class="top-nav__right">
          <div class="top-nav__actions">
            <div class="header-glossary">
              <div class="custom-select-wrapper" id="glossary-custom-select">
                <div class="custom-select-trigger">
                  <span id="custom-select-label">No Category</span>
                  <i data-lucide="chevron-down" style="width:14px;height:14px;"></i>
                </div>
                <div class="custom-options">
                  <div class="custom-option is-selected" data-value="">No Category</div>
                  <% (categories || []).forEach(cat => { %>
                    <div class="custom-option" data-value="<%= cat._id %>"><%= cat.name %></div>
                  <% }); %>
                </div>
              </div>
              <input type="hidden" id="category-select" value="">
            </div>
          </div>
        </div>
      </header>

      <header class="header-wrapper">
        <!-- Language controls -->
        <div class="lang-pill-container">
          <div class="lang-scroll-area">
            <div class="lang-group">
              <span class="lang-group-label">FROM</span>
              <div class="lang-source-pills" id="source-lang-pills">
                <button class="src-pill is-active" data-code="en" onclick="setSourceLang('en')">English</button>
                <button class="src-pill" data-code="ar" onclick="setSourceLang('ar')">Arabic</button>
                <button class="src-pill" data-code="es" onclick="setSourceLang('es')">Spanish</button>
              </div>
            </div>
            <div class="lang-arrow" id="swap-arrow" onclick="swapLanguages()" title="Swap languages" style="cursor:pointer;"><i data-lucide="arrow-right-left" style="width:16px;height:16px;color:var(--gold-400);"></i></div>
            <div class="lang-group">
              <span class="lang-group-label">TO</span>
              <div class="lang-target-pills" id="target-lang-pills">
                <button class="tgt-pill is-active" data-code="ar" onclick="toggleTargetLang('ar')">Arabic</button>
                <button class="tgt-pill" data-code="en" onclick="toggleTargetLang('en')">English</button>
                <button class="tgt-pill" data-code="es" onclick="toggleTargetLang('es')">Spanish</button>
              </div>
            </div>
          </div>
        </div>
      </header>

      <div class="page-body">
        <div class="translate-container">
          <!-- Edit Memory Bar (User Translations) — above panels -->
          <div class="memory-bar" id="memory-bar" style="display:none;">
            <div class="memory-bar-left">
              <i data-lucide="brain" style="width:14px;height:14px;"></i>
              <span class="memory-bar-label">Memory</span>
              <span class="memory-bar-count" id="memory-bar-count">0</span>
              <% if (typeof user !== 'undefined' && user) { %>
              <a href="/memory" class="memory-manage-link" title="Manage all memories">
                <i data-lucide="settings-2" style="width:12px;height:12px;"></i>
              </a>
              <% } %>
            </div>
            <div class="memory-chips" id="memory-chips"></div>
          </div>

          <div class="translate-panels" id="translate-panels">
            <div class="translate-panel source-panel" id="source-panel">
              <div class="panel-header">
                <span class="panel-label">Source</span>
                <button class="btn btn-ghost btn-sm" id="clear-source" title="Clear" style="opacity:0;transition:opacity .2s;">
                  <i data-lucide="x" style="width:13px;height:13px;"></i>
                </button>
              </div>
              <div class="source-input-wrap">
                <div class="source-highlights" id="source-highlights"></div>
                <textarea class="translate-input" id="source-text" placeholder="Type or paste text here..." autofocus autocomplete="off" autocorrect="off" spellcheck="false"></textarea>
                <div class="ghost-overlay" id="ghost-overlay"></div>
                <div class="ac-dropdown" id="ac-dropdown" style="display:none;"></div>
                <div id="recording-indicator" style="display:none;position:absolute;top:8px;right:8px;background:rgba(239,68,68,0.9);color:#fff;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:500;animation:pulse 1s infinite;">
                  <span style="display:inline-block;width:6px;height:6px;background:#fff;border-radius:50%;margin-right:6px;"></span>Recording...
                </div>
              </div>
              <div class="panel-footer">
                <span class="char-count" id="source-count">0</span>
                <span class="auto-save-dot" id="auto-save-indicator" title="Auto-saved"></span>
                <div style="display:flex;gap:2px;margin-left:auto;">
                  <button class="btn btn-ghost btn-sm" id="text-decrease" title="Decrease text size" style="padding:2px 6px;font-size:10px;">A-</button>
                  <button class="btn btn-ghost btn-sm" id="text-increase" title="Increase text size" style="padding:2px 6px;font-size:12px;">A+</button>
                  <button class="btn btn-ghost btn-sm" id="voice-btn" title="Voice input"><i data-lucide="mic" style="width:14px;height:14px;"></i></button>
                </div>
                <button class="btn btn-ghost btn-sm" id="new-conversation-btn" title="Start new conversation" style="font-size:11px;padding:3px 10px;">
                  <i data-lucide="plus" style="width:12px;height:12px;"></i> New
                </button>
              </div>
              <!-- Resize Handle -->
              <div class="panel-resize-handle" id="panel-resize-handle" title="Drag to resize">
                <span class="resize-grip"></span>
              </div>
            </div>
            <div class="translate-targets" id="translate-targets"></div>
          </div>

          <!-- Glossary Detection Bar — below panels -->
          <div class="gloss-bar" id="gloss-bar" style="display:none;">
            <div class="gloss-bar-left">
              <label class="gloss-switch" id="gloss-master">
                <input type="checkbox" id="gloss-master-cb" checked>
                <span class="gloss-slider"></span>
              </label>
              <span class="gloss-bar-label">Categories</span>
              <span class="gloss-bar-count" id="gloss-bar-count">0</span>
            </div>
            <div class="gloss-chips" id="gloss-chips"></div>
          </div>

          <!-- Terms Drawer -->
          <div class="terms-drawer" id="terms-drawer" style="display:none;">
            <div class="drawer-header" id="drawer-header">
              <div style="display:flex;align-items:center;gap:var(--space-sm);">
                <i data-lucide="book-open" style="width:14px;height:14px;color:var(--gold-400);"></i>
                <span class="drawer-title" id="drawer-title">Terms</span>
                <span class="badge badge-gold" id="drawer-count">0</span>
              </div>
              <div style="display:flex;gap:4px;">
                <button class="btn btn-primary btn-sm" id="add-term-drawer-btn" style="font-size:11px;padding:3px 10px;">
                  <i data-lucide="plus" style="width:11px;height:11px;"></i> Add
                </button>
                <button class="btn btn-ghost btn-sm btn-icon" id="toggle-drawer">
                  <i data-lucide="chevron-down" style="width:14px;height:14px;"></i>
                </button>
              </div>
            </div>
            <div class="drawer-body" id="drawer-body">
              <table class="data-table" id="terms-table">
                <thead>
                  <tr>
                    <th>English</th>
                    <th>Arabic</th>
                    <th>Spanish</th>
                  </tr>
                </thead>
                <tbody id="terms-tbody"></tbody>
              </table>
              <div id="terms-empty" style="display:none;padding:var(--space-md);text-align:center;color:var(--text-muted);font-size:var(--text-sm);">No terms yet.</div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add/Edit Term Modal -->
  <div class="modal-backdrop" id="term-modal-backdrop" onclick="Modal.close('term-modal')"></div>
  <div class="modal" id="term-modal" style="max-width:480px;">
    <div class="modal-header">
      <h3 id="term-modal-title">Add Term</h3>
      <button class="modal-close" onclick="Modal.close('term-modal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-term-id">
      <p style="font-size:11px;color:var(--text-muted);margin:0 0 var(--space-md);line-height:1.5;">Enter the same word/phrase in at least 2 languages. All directions are automatic.</p>
      <div style="display:flex;gap:var(--space-md);align-items:flex-start;">
        <div style="flex:1;">
          <div class="term-lang-flag" style="width:100%;margin-bottom:4px;">EN</div>
          <input type="text" class="form-input" id="modal-term-en" placeholder="English term">
        </div>
        <div style="flex:1;">
          <div class="term-lang-flag" style="width:100%;margin-bottom:4px;background:rgba(34,139,34,0.15);color:#4ade80;">AR</div>
          <input type="text" class="form-input" id="modal-term-ar" placeholder="المصطلح بالعربية" dir="rtl">
        </div>
        <div style="flex:1;">
          <div class="term-lang-flag" style="width:100%;margin-bottom:4px;background:rgba(59,130,246,0.15);color:#60a5fa;">ES</div>
          <input type="text" class="form-input" id="modal-term-es" placeholder="Término en español">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="Modal.close('term-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveTermFromModal()">Save Term</button>
    </div>
  </div>

  <!-- Login Suggestion Modal -->
  <div class="modal-backdrop" id="login-modal-backdrop" onclick="Modal.close('login-modal')"></div>
  <div class="modal" id="login-modal" style="max-width:480px;">
    <div class="modal-header">
      <h3 class="modal-title" style="display:flex;align-items:center;gap:8px;"><i data-lucide="shield-alert" style="color:var(--gold-400);"></i> Login Required</h3>
      <button class="modal-close" onclick="Modal.close('login-modal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="color:var(--text-secondary);font-size:14px;line-height:1.5;margin:0 0 16px;">
        You must be logged in to save your translation history and use the personal edits memory system.
      </p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="Modal.close('login-modal')">Continue as Guest</button>
      <a href="/auth/login" class="btn btn-primary">Login Now</a>
    </div>
  </div>

  <!-- Inline Edit Popover -->
  <div class="edit-popover" id="edit-popover">
    <div class="edit-popover-header">
      <div class="edit-popover-title">
        <i data-lucide="edit-3"></i> Edit <span id="po-source-word" style="color:var(--text-primary);text-transform:none;letter-spacing:normal;"></span>
      </div>
      <button class="btn btn-ghost btn-icon btn-sm" onclick="closeEditPopover()" style="width:20px;height:20px;"><i data-lucide="x"></i></button>
    </div>
    <div>
      <input type="text" id="po-target-input" placeholder="Enter translation..." autocomplete="off">
    </div>
    <div class="edit-popover-saved" id="po-saved-area" style="display:none;">
      <span>Saved: <b id="po-saved-word"></b></span>
      <button class="btn btn-ghost btn-sm" onclick="applySavedEdit()" style="font-size:10px;padding:2px 6px;">Use</button>
    </div>
    <div class="edit-popover-actions">
      <button class="btn btn-primary btn-sm" onclick="saveUserEdit()" style="padding:4px 12px;font-size:11px;">Save</button>
    </div>
    <input type="hidden" id="po-word-idx">
    <input type="hidden" id="po-target-lang">
    <input type="hidden" id="po-google-translation">
  </div>

  <script src="/js/app.js?v=2"></script>
  <script>
    lucide.createIcons();
    
    // Auth state
    var isLoggedIn = <%= (typeof user !== 'undefined' && user) ? 'true' : 'false' %>;

    // Translation state
    var translateTimer = null;
    var useGlossary = true;
    var currentSourceLang = 'en';
    var activeTargets = ['ar'];
    var DEBOUNCE = 600;
    var lastTranslations = {};
    var chipStates = {}; // For Glossary
    var userEditsState = {}; // Array of edits from API
    var memoryChipStates = {}; // Local toggle states for User Edits: editId -> boolean
    var hoveredMemoryEditId = null;
    var lastGlossarySegments = []; // Store glossary segments for saving
    var currentSessionId = null;
    var autoSaveTimer = null;
    var currentTerms = [];
    var allTermObjects = [];
    var syncStorageKey = 'translation-memory-sync';
    var lastSyncToken = 0;
    var acDropdown = document.getElementById('ac-dropdown');
    var acActiveIdx = -1;
    var acMatches = [];

    var srcText = document.getElementById('source-text');
    var catSelect = document.getElementById('category-select');
    var targetsEl = document.getElementById('translate-targets');
    var drawerEl = document.getElementById('terms-drawer');
    var clearBtn = document.getElementById('clear-source');
    var glossBar = document.getElementById('gloss-bar');
    var glossChipsEl = document.getElementById('gloss-chips');
    var glossMasterCb = document.getElementById('gloss-master-cb');
    var autoSaveDot = document.getElementById('auto-save-indicator');
    var sourceHighlights = document.getElementById('source-highlights');
    var ghostOverlay = document.getElementById('ghost-overlay');
    var translateContainer = document.querySelector('.translate-container');
    var currentGhostSuggestion = '';
    var pendingSourceResolve = null;
    var textSize = 16;

    // Text size controls - applies to source and all target outputs
    function applyTextSize() {
      srcText.style.fontSize = textSize + 'px';
      sourceHighlights.style.fontSize = textSize + 'px';
      ghostOverlay.style.fontSize = textSize + 'px';
      document.querySelectorAll('.translate-output').forEach(function(el) {
        el.style.fontSize = textSize + 'px';
      });
      if (translateContainer) {
        translateContainer.style.setProperty('--ui-scale', String(textSize / 16));
        translateContainer.style.setProperty('--dynamic-text-size', textSize + 'px');
      }
    }
    
    document.getElementById('text-increase').addEventListener('click', function() {
      if (textSize < 32) { textSize += 2; applyTextSize(); }
    });
    document.getElementById('text-decrease').addEventListener('click', function() {
      if (textSize > 10) { textSize -= 2; applyTextSize(); }
    });

    // Voice input using MediaRecorder + backend Whisper API
    var mediaRecorder = null;
    var audioChunks = [];
    var isRecording = false;
    var voiceBtn = document.getElementById('voice-btn');
    var recordingIndicator = document.getElementById('recording-indicator');
    
    if (voiceBtn && navigator.mediaDevices) {
      voiceBtn.addEventListener('click', async function() {
        if (!isRecording) {
          try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm' });
            audioChunks = [];
            
            mediaRecorder.ondataavailable = function(e) { audioChunks.push(e.data); };
            
            mediaRecorder.onstop = async function() {
              stream.getTracks().forEach(t => t.stop());
              recordingIndicator.style.display = 'none';
              voiceBtn.style.color = '';
              const blob = new Blob(audioChunks, { type: 'audio/webm' });
              
              // Convert to base64
              const reader = new FileReader();
              reader.onload = async function() {
                const base64 = reader.result.split(',')[1];
                const lang = currentSourceLang === 'ar' ? 'ar' : currentSourceLang === 'es' ? 'es' : 'en';
                
                Toast.success('Processing voice...');
                
                try {
                  const res = await fetch('/api/speech-to-text', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ audio: base64, lang: lang })
                  });
                  const data = await res.json();
                  
                  if (data.success && data.text) {
                    srcText.value += (srcText.value ? ' ' : '') + data.text;
                    srcText.dispatchEvent(new Event('input'));
                    Toast.success('Voice captured!');
                  } else {
                    Toast.error(data.error || 'Speech recognition failed');
                  }
                } catch (err) {
                  Toast.error('Speech API error');
                }
              };
              reader.readAsDataURL(blob);
            };
            
            mediaRecorder.start();
            isRecording = true;
            voiceBtn.style.color = '#ef4444';
            recordingIndicator.style.display = 'block';
            Toast.success('Recording... Click to stop');
            
            // Auto-stop after 30 seconds
            setTimeout(function() {
              if (isRecording && mediaRecorder && mediaRecorder.state === 'recording') {
                mediaRecorder.stop();
                isRecording = false;
                recordingIndicator.style.display = 'none';
                voiceBtn.style.color = '';
              }
            }, 30000);
            
          } catch (err) {
            Toast.error('Microphone access denied');
          }
        } else {
          if (mediaRecorder && mediaRecorder.state === 'recording') {
            mediaRecorder.stop();
          }
          isRecording = false;
          recordingIndicator.style.display = 'none';
          voiceBtn.style.color = '';
        }
      });
    } else if (voiceBtn) {
      voiceBtn.style.opacity = '0.5';
      voiceBtn.title = 'Voice not supported';
    }

    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
    function esc(s) { return escapeHtml(s); }
    function enc(s) { return encodeURIComponent(s); }
    function normalizeForMatch(s) {
      return String(s || '')
        .normalize('NFKC')
        .replace(/[\u064B-\u065F\u0670\u0640]/g, '')
        .replace(/[إأآٱ]/g, 'ا')
        .replace(/ى/g, 'ي')
        .replace(/ة/g, 'ه')
        .replace(/ؤ/g, 'و')
        .replace(/ئ/g, 'ي')
        .replace(/[^\p{L}\p{N}\s]/gu, ' ')
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();
    }

    function normalizePhraseTokens(s) {
      var norm = normalizeForMatch(s || '');
      if (!norm) return [];
      return norm.split(' ').filter(function(t) { return !!t; });
    }

    function tokenCompatible(normToken, normPhraseToken, langCode) {
      if (!normToken || !normPhraseToken) return false;
      if (normToken === normPhraseToken) return true;
      if (normToken.indexOf(normPhraseToken) !== -1 || normPhraseToken.indexOf(normToken) !== -1) return true;
      if (langCode === 'ar') {
        if (normToken === ('و' + normPhraseToken)) return true;
        if (normPhraseToken === ('و' + normToken)) return true;
      }
      return false;
    }

    function setSourceLang(code) {
      currentSourceLang = code;
      document.querySelectorAll('.src-pill').forEach(function(p) { p.classList.toggle('is-active', p.dataset.code === code); });
      activeTargets = activeTargets.filter(function(t) { return t !== code; });
      syncTargetPills(); buildTargetPanels();
      updateAcDirection();
      if (catSelect.value) loadDrawerTerms(catSelect.value);
      if (srcText.value.trim()) doTranslate();
    }

    function toggleTargetLang(code) {
      if (code === currentSourceLang) return;
      activeTargets = [code];
      syncTargetPills(); buildTargetPanels();
      var cachedSegs = [];
      for (var k in lastTranslations) { if (lastTranslations[k].segments) { cachedSegs = lastTranslations[k].segments; break; } }
      if (cachedSegs.length) renderChips(cachedSegs);
      if (srcText.value.trim()) doTranslate();
    }

    function swapLanguages() {
      if (!activeTargets.length) return;
      var oldSource = currentSourceLang;
      var newSource = activeTargets[0];
      currentSourceLang = newSource;
      activeTargets = [oldSource];
      document.querySelectorAll('.src-pill').forEach(function(p) { p.classList.toggle('is-active', p.dataset.code === newSource); });
      syncTargetPills(); buildTargetPanels();
      updateAcDirection();
      // Swap text: put the translation into source
      var targetOutput = document.getElementById('output-' + oldSource);
      if (targetOutput && targetOutput.textContent && !targetOutput.querySelector('.placeholder-text')) {
        var translatedText = targetOutput.textContent.trim();
        srcText.value = translatedText;
        document.getElementById('source-count').textContent = translatedText.length;
        clearBtn.style.opacity = translatedText ? '1' : '0';
      }
      if (srcText.value.trim()) doTranslate();
    }

    function updateAcDirection() {
      var rtlLangs = ['ar'];
      var acEl = document.getElementById('ac-dropdown');
      var srcInput = document.getElementById('source-text');
      var highlights = document.getElementById('source-highlights');
      var overlay = document.getElementById('ghost-overlay');
      var isRtl = rtlLangs.indexOf(currentSourceLang) > -1;
      
      var direction = isRtl ? 'rtl' : 'ltr';
      var align = isRtl ? 'right' : 'left';
      
      if (acEl) { acEl.style.direction = direction; acEl.style.textAlign = align; }
      if (srcInput) { srcInput.style.direction = direction; srcInput.style.textAlign = align; }
      if (highlights) { highlights.style.direction = direction; highlights.style.textAlign = align; }
      if (overlay) { overlay.style.direction = direction; overlay.style.textAlign = align; }
    }

    function syncTargetPills() {
      document.querySelectorAll('.tgt-pill').forEach(function(p) {
        p.classList.toggle('is-hidden', p.dataset.code === currentSourceLang);
        p.classList.toggle('is-active', activeTargets.indexOf(p.dataset.code) > -1);
      });
    }

    function buildTargetPanels() {
      var rtlLangs = ['ar'];
      targetsEl.innerHTML = activeTargets.map(function(code) {
        var pill = document.querySelector('.tgt-pill[data-code="' + code + '"]');
        var name = pill ? pill.textContent : code;
        var isRtl = rtlLangs.indexOf(code) > -1;
        return '<div class="translate-panel target-panel" data-lang="' + code + '">'
          + '<div class="panel-header"><span class="panel-label">' + name + '</span>'
          + '<button class="btn btn-ghost btn-sm" onclick="copyPanel(\'' + code + '\')" title="Copy"><i data-lucide="copy"></i></button></div>'
          + '<div class="translate-output" id="output-' + code + '" style="font-size:' + textSize + 'px;"' + (isRtl ? ' data-dir="rtl"' : '') + '><span class="placeholder-text">Translation...</span></div>'
          + '<div class="panel-footer"><span class="char-count" id="count-' + code + '">0</span>'
          + '<div class="spinner spinner-sm" id="loading-' + code + '" style="display:none;"></div></div></div>';
      }).join('');
      lucide.createIcons();
    }

    function copyPanel(code) {
      var el = document.getElementById('output-' + code);
      if (el) { navigator.clipboard.writeText(el.textContent); Toast.success('Copied!'); }
    }

    srcText.addEventListener('input', function() {
      document.getElementById('source-count').textContent = srcText.value.length;
      clearBtn.style.opacity = srcText.value ? '1' : '0';
      updateSourceHighlights();
      filterGlossaryTableLive();
      if (typeof updateGhostText === 'function') updateGhostText();
      clearTimeout(translateTimer);
      if (!srcText.value.trim()) {
        document.querySelectorAll('.translate-output').forEach(function(el) { el.innerHTML = '<span class="placeholder-text">Translation...</span>'; });
        lastTranslations = {}; chipStates = {}; renderChips([]);
        userEditsState = []; memoryChipStates = {}; renderMemoryChips([]);
        sourceHighlights.innerHTML = '';
        ghostOverlay.innerHTML = ''; currentGhostSuggestion = '';
        return;
      }
      translateTimer = setTimeout(doTranslate, DEBOUNCE);
    });

    srcText.addEventListener('scroll', function() {
      sourceHighlights.scrollTop = srcText.scrollTop;
      sourceHighlights.scrollLeft = srcText.scrollLeft;
      ghostOverlay.scrollTop = srcText.scrollTop;
      ghostOverlay.scrollLeft = srcText.scrollLeft;
    });

    function doTranslate() {
      var text = srcText.value;
      if (!text.trim() || !activeTargets.length) return;
      activeTargets.forEach(function(c) {
        var ld = document.getElementById('loading-' + c); if (ld) ld.style.display = 'inline-block';
        var out = document.getElementById('output-' + c); if (out) out.style.opacity = '0.5';
      });

      var disabledTerms = [];
      for (var tid in chipStates) {
        if (chipStates[tid] === false) disabledTerms.push(tid);
      }

      api('/api/translate', {
        method: 'POST',
        body: JSON.stringify({
          text: text,
          source_lang: currentSourceLang,
          target_langs: activeTargets,
          category_id: catSelect.value || null,
          use_glossary: useGlossary,
          disabled_terms: disabledTerms
        })
      }).then(function(res) {
        console.log('[DEBUG][doTranslate] API response received');
        console.log('[DEBUG][doTranslate] Translation keys:', Object.keys(res.translations || {}));
        console.log('[DEBUG][doTranslate] userEdits count:', (res.userEdits || []).length);
        
        lastTranslations = res.translations || {};
        var allSegs = [], seenIds = {};
        for (var code in lastTranslations) {
          var segs = lastTranslations[code].segments || [];
          for (var i = 0; i < segs.length; i++) {
            if (segs[i].is_glossary && !seenIds[segs[i].term_id]) {
              seenIds[segs[i].term_id] = true;
              allSegs.push(segs[i]);
              if (!(segs[i].term_id in chipStates)) chipStates[segs[i].term_id] = true;
            }
          }
        }
        
        var apiEdits = res.userEdits || [];
        console.log('[DEBUG][doTranslate] API returned', apiEdits.length, 'edits. Local has', userEditsState.length, 'edits.');
        userEditsState = apiEdits.slice();
        
        console.log('[DEBUG][doTranslate] userEditsState after merge:', JSON.stringify(userEditsState.map(function(e) { return { id: e.editId, src: e.sourceWord, tgt: e.userTranslation, lang: e.targetLanguage }; })));
        
        userEditsState.forEach(function(edit) {
          if (!(edit.editId in memoryChipStates)) memoryChipStates[edit.editId] = true;
        });

        lastGlossarySegments = allSegs;
        renderChips(allSegs);
        renderMemoryChips(userEditsState);
        rerenderAllOutputs();
        if (isLoggedIn) autoSave();
      }).catch(function(e) {
        console.error('[DEBUG][doTranslate] Error:', e.message);
        Toast.error(e.message || 'Translation failed.');
      }).finally(function() {
          activeTargets.forEach(function(c) {
            var ld = document.getElementById('loading-' + c); if (ld) ld.style.display = 'none';
            var out = document.getElementById('output-' + c); if (out) out.style.opacity = '1';
          });
        });
    }

    // Helper: try to find the source word for a given target word by checking the source text
    function findSourceWordForTarget(targetWord, code) {
      // The source text is in srcText.value. We need to figure out which source word 
      // produced this particular target word. Since we have the full source text and don't have 
      // a word-level alignment, we'll use a heuristic: try translating each source word individually
      // and match. But that's expensive. Instead, we provide the target word itself as fallback
      // and set the source word to the first word in the source text that starts with similar letters.
      // Better approach: just use the target word as the source_word identifier for the popover.
      // The USER will see which word they're editing.
      return targetWord;
    }

    function renderArabicOutputWithMemory(out, fullText, data, code) {
      var baseText = String(data.google_full_translation || fullText || '');
      var hints = (data.memoryHints || []).filter(function(h) {
        var hid = String(h && h.editId ? h.editId : '');
        return h && hid && h.to && memoryChipStates[hid] !== false;
      });
      if (!hints.length) {
        out.innerHTML = escapeHtml(baseText).replace(/\n/g, '<br>');
        return;
      }
      var editById = {};
      (userEditsState || []).forEach(function(e) {
        if (!e || !e.editId) return;
        editById[String(e.editId)] = e;
      });
      hints.sort(function(a, b) {
        return String(b.from || '').length - String(a.from || '').length;
      });
      var renderedText = baseText;
      for (var ai = 0; ai < hints.length; ai++) {
        var activeHint = hints[ai];
        var fromText = String(activeHint.from || '').trim();
        var toTextApply = String(activeHint.to || '').trim();
        if (!fromText || !toTextApply) continue;
        var fromPos = renderedText.indexOf(fromText);
        if (fromPos === -1) continue;
        renderedText = renderedText.slice(0, fromPos) + toTextApply + renderedText.slice(fromPos + fromText.length);
      }
      var ranges = [];
      var occupied = [];
      function overlaps(start, end) {
        for (var i = 0; i < occupied.length; i++) {
          if (start < occupied[i].end && end > occupied[i].start) return true;
        }
        return false;
      }
      for (var hi = 0; hi < hints.length; hi++) {
        var hint = hints[hi];
        var toText = String(hint.to || '').trim();
        if (!toText) continue;
        var pos = renderedText.indexOf(toText);
        while (pos !== -1) {
          var endPos = pos + toText.length;
          if (!overlaps(pos, endPos)) {
            ranges.push({ start: pos, end: endPos, hint: hint });
            occupied.push({ start: pos, end: endPos });
            break;
          }
          pos = renderedText.indexOf(toText, pos + 1);
        }
      }
      if (!ranges.length) {
        out.innerHTML = escapeHtml(renderedText).replace(/\n/g, '<br>');
        return;
      }
      ranges.sort(function(a, b) { return a.start - b.start; });
      var html = '';
      var cursor = 0;
      for (var ri = 0; ri < ranges.length; ri++) {
        var range = ranges[ri];
        if (range.start > cursor) {
          html += escapeHtml(renderedText.slice(cursor, range.start)).replace(/\n/g, '<br>');
        }
        var editId = String(range.hint.editId || '');
        var edit = editById[editId] || {};
        var classes = ['tgt-word', 'has-user-edit', 'is-user-edited'];
        if (hoveredMemoryEditId && hoveredMemoryEditId === editId) classes.push('is-memory-hovered');
        var dataset = ' data-lang="' + code + '"'
          + ' data-edit-id="' + escapeHtml(editId) + '"'
          + ' data-google="' + escapeHtml(range.hint.from || edit.googleTranslation || '') + '"'
          + ' data-source="' + escapeHtml(edit.sourceWord || range.hint.from || '') + '"'
          + ' data-saved="' + escapeHtml(edit.userTranslation || range.hint.to || '') + '"';
        var token = renderedText.slice(range.start, range.end);
        html += '<span class="' + classes.join(' ') + '"' + dataset + ' title="Memory: Edit applied" onclick="openEditPopover(this)">' + escapeHtml(token) + '<span class="memory-dot"></span></span>';
        cursor = range.end;
      }
      if (cursor < renderedText.length) {
        html += escapeHtml(renderedText.slice(cursor)).replace(/\n/g, '<br>');
      }
      out.innerHTML = html;
    }

    function rerenderAllOutputs() {
      console.log('[DEBUG][rerender] ──── RERENDER START ────');
      if (!lastTranslations) return;
      
      for (var code in lastTranslations) {
        if (code === 'undefined' || !code) continue;
        var data = lastTranslations[code];
        var out = document.getElementById('output-' + code);
        if (!out || !data) continue;
        
        var fullText = data.full_translation || '';
        if (code === 'ar') {
          renderArabicOutputWithMemory(out, fullText, data, code);
          var arCnt = document.getElementById('count-' + code);
          if (arCnt) arCnt.textContent = fullText.length;
          continue;
        }
        var wordsArray = fullText.split(/(\s+)/);
        var htmlParts = [];
        
        // ── Step 1: Build glossary word-index set ──
        // Pre-scan which word indices belong to glossary terms (supports multi-word)
        var glossaryWordMap = {}; // wIdx → { source, termId }
        if (data.segments && useGlossary) {
          for (var si = 0; si < data.segments.length; si++) {
            var seg = data.segments[si];
            if (!seg || !seg.is_glossary || chipStates[seg.term_id] === false) continue;
            
            var termForLang = (seg['term_' + code] || seg.translation || '').trim();
            if (!termForLang) continue;
            
            // Find this term in the full translation text (case-insensitive)
            var termLower = termForLang.toLowerCase();
            var fullLower = fullText.toLowerCase();
            var searchPos = 0;
            while (true) {
              var foundAt = fullLower.indexOf(termLower, searchPos);
              if (foundAt === -1) break;
              searchPos = foundAt + 1;
              
              // Map character positions to word indices
              var charPos = 0;
              for (var wi = 0; wi < wordsArray.length; wi++) {
                var wEnd = charPos + wordsArray[wi].length;
                // If this word overlaps with the glossary term range
                if (charPos < foundAt + termForLang.length && wEnd > foundAt && wordsArray[wi].trim()) {
                  glossaryWordMap[wi] = { source: seg.source, termId: seg.term_id };
                }
                charPos = wEnd;
              }
            }
          }
        }
        
        // ── Step 2: Build contextual memory spans (phrase-aware, order-safe) ──
        var langEdits = (userEditsState || []).filter(function(e) {
          return e.targetLanguage === code && memoryChipStates[String(e.editId)] !== false;
        });
        var contentTokens = [];
        for (var cw = 0; cw < wordsArray.length; cw++) {
          if (!wordsArray[cw] || !wordsArray[cw].trim()) continue;
          if (glossaryWordMap[cw]) continue;
          contentTokens.push({
            wordIndex: cw,
            normalized: normalizeForMatch(wordsArray[cw])
          });
        }
        var spanStartMap = {};
        var spanCovered = {};
        
        function isWordIndexFree(startIdx, endIdx) {
          for (var chk = startIdx; chk <= endIdx; chk++) {
            if (spanCovered[chk] || glossaryWordMap[chk]) return false;
          }
          return true;
        }
        
        function findBestSpanForEdit(edit) {
          var phraseCandidates = [];
          if (edit.currentTranslation) phraseCandidates.push(edit.currentTranslation);
          if (edit.googleTranslation) phraseCandidates.push(edit.googleTranslation);
          if (edit.originalTranslation) phraseCandidates.push(edit.originalTranslation);
          phraseCandidates = Array.from(new Set(phraseCandidates.map(function(p) { return String(p || '').trim(); }).filter(function(p) { return !!p; })));
          var best = null;
          
          for (var pc = 0; pc < phraseCandidates.length; pc++) {
            var phraseTokens = normalizePhraseTokens(phraseCandidates[pc]);
            if (!phraseTokens.length) continue;
            if (code === 'ar') {
              var userTokens = normalizePhraseTokens(edit.userTranslation || '');
              if (!userTokens.length || userTokens.length !== phraseTokens.length) continue;
            }
            for (var i = 0; i <= contentTokens.length - phraseTokens.length; i++) {
              var ok = true;
              for (var j = 0; j < phraseTokens.length; j++) {
                if (!tokenCompatible(contentTokens[i + j].normalized, phraseTokens[j], code)) {
                  ok = false;
                  break;
                }
              }
              if (!ok) continue;
              var startWordIdx = contentTokens[i].wordIndex;
              var endWordIdx = contentTokens[i + phraseTokens.length - 1].wordIndex;
              if (!isWordIndexFree(startWordIdx, endWordIdx)) continue;
              var usage = parseInt(edit.usageCount || 0, 10) || 0;
              var score = (phraseTokens.length * 100) + usage;
              if (!best || score > best.score) {
                best = { startWordIdx: startWordIdx, endWordIdx: endWordIdx, score: score };
              }
            }
          }
          return best;
        }
        
        for (var le = 0; le < langEdits.length; le++) {
          var edit = langEdits[le];
          var bestSpan = findBestSpanForEdit(edit);
          if (!bestSpan) continue;
          spanStartMap[bestSpan.startWordIdx] = {
            edit: edit,
            startWordIdx: bestSpan.startWordIdx,
            endWordIdx: bestSpan.endWordIdx
          };
          for (var cov = bestSpan.startWordIdx; cov <= bestSpan.endWordIdx; cov++) {
            spanCovered[cov] = true;
          }
        }
        
        // ── Step 3: Render each word ──
        for (var wIdx = 0; wIdx < wordsArray.length; wIdx++) {
          var wordToken = wordsArray[wIdx];
          if (!wordToken.trim()) {
            htmlParts.push(wordToken.replace(/\n/g, '<br>'));
            continue;
          }
          
          var cleanWord = wordToken.replace(/[.,/#!$%^&*;:{}=\-_`~()\u060C\u061B\u061F]/g,'').toLowerCase();
          var glossaryMeta = glossaryWordMap[wIdx] || null;
          var isGlossaryWord = !!glossaryMeta;
          
          // ── Check memory edits via spans ──
          var spanMeta = spanStartMap[wIdx] || null;
          var matchedEdit = spanMeta ? spanMeta.edit : null;
          if (!matchedEdit && spanCovered[wIdx]) {
            continue;
          }
          
          var displayWord = wordToken;
          var classes = ['tgt-word'];
          if (isGlossaryWord) classes.push('glossary-word');
          var dataset = ' data-raw="' + escapeHtml(cleanWord) + '" data-lang="' + code + '" data-idx="' + wIdx + '"';
          var titleAttr = '';
          var dotHtml = '';
          
          if (matchedEdit) {
            dataset += ' data-google="' + escapeHtml(matchedEdit.googleTranslation || cleanWord) + '"';
            dataset += ' data-source="' + escapeHtml(matchedEdit.sourceWord) + '"';
            classes.push('has-user-edit');
            if (hoveredMemoryEditId && hoveredMemoryEditId === String(matchedEdit.editId)) classes.push('is-memory-hovered');
            dotHtml = '<span class="memory-dot"></span>';
            
            if (memoryChipStates[matchedEdit.editId]) {
              classes.push('is-user-edited');
              var trailing = '';
              var trailToken = spanMeta ? (wordsArray[spanMeta.endWordIdx] || wordToken) : wordToken;
              var trailingMatch = trailToken.match(/([.,!?;:،。]+)$/);
              if (trailingMatch) trailing = trailingMatch[1];
              displayWord = matchedEdit.userTranslation + trailing;
              dataset += ' data-saved="' + escapeHtml(matchedEdit.userTranslation) + '"';
              dataset += ' data-edit-id="' + matchedEdit.editId + '"';
              titleAttr = isGlossaryWord
                ? ' title="Categories + Memory: Edit applied"'
                : ' title="Memory: Edit applied"';
            } else {
              dataset += ' data-saved="' + escapeHtml(matchedEdit.userTranslation) + '"';
              dataset += ' data-edit-id="' + matchedEdit.editId + '"';
              titleAttr = isGlossaryWord
                ? ' title="Categories + Memory: You have a saved edit for this"'
                : ' title="Memory: You have a saved edit for this"';
            }
          } else {
            var sourceWord = isGlossaryWord ? (glossaryMeta.source || cleanWord) : cleanWord;
            dataset += ' data-google="' + escapeHtml(cleanWord) + '"';
            dataset += ' data-source="' + escapeHtml(sourceWord) + '"';
            if (isGlossaryWord) dataset += ' data-source-fixed="1"';
            if (isGlossaryWord) titleAttr = ' title="Category: ' + escapeHtml(glossaryMeta.source || '') + '"';
          }
          
          htmlParts.push('<span class="' + classes.join(' ') + '"' + dataset + titleAttr + ' onclick="openEditPopover(this)">' + escapeHtml(displayWord) + dotHtml + '</span>');
        }

        out.innerHTML = htmlParts.join('');
        var cnt = document.getElementById('count-' + code);
        if (cnt) cnt.textContent = fullText.length;
      }
      console.log('[DEBUG][rerender] ──── RERENDER DONE ────');
      lucide.createIcons();
    }

    // --- Per-User Memory Front-End Logic ---
    var memoryBar = document.getElementById('memory-bar');
    var memoryChipsEl = document.getElementById('memory-chips');
    var editPopover = document.getElementById('edit-popover');
    var currentEditWordEl = null;

    function renderMemoryChips(edits) {
      if (!edits || !edits.length) {
        memoryBar.style.display = 'none';
        return;
      }
      memoryBar.style.display = 'flex';
      document.getElementById('memory-bar-count').textContent = edits.length;
      memoryChipsEl.innerHTML = edits.map(function(edit) {
        var editId = String(edit.editId || '');
        var isOn = memoryChipStates[editId] !== false;
        return '<span class="m-chip' + (isOn ? '' : ' is-off') + '" data-edit-id="' + editId + '" onclick="toggleMemoryChip(\'' + editId + '\', this)" onmouseenter="setMemoryHover(\'' + editId + '\', true)" onmouseleave="setMemoryHover(\'' + editId + '\', false)">'
          + '<span class="m-chip-dot"></span>' + escapeHtml(edit.sourceWord) + ' \u2192 ' + escapeHtml(edit.userTranslation)
          + '</span>';
      }).join('');
    }

    window.setMemoryHover = function(editId, isHovering) {
      hoveredMemoryEditId = isHovering ? String(editId) : null;
      updateSourceHighlights();
      rerenderAllOutputs();
    };

    window.toggleMemoryChip = function(editId, el) {
      var key = String(editId || '');
      memoryChipStates[key] = (memoryChipStates[key] === false);
      el.classList.toggle('is-off', !memoryChipStates[key]);
      updateSourceHighlights();
      rerenderAllOutputs(); 
    };

    function pruneDeletedMemory(payload) {
      if (!payload) return;
      var deletedIds = payload.deletedIds || [];
      var deletedSyntheticIds = payload.deletedSyntheticIds || [];
      if (!deletedIds.length && !deletedSyntheticIds.length) return;
      var deletedSet = new Set(deletedIds.concat(deletedSyntheticIds));
      userEditsState = (userEditsState || []).filter(function(edit) {
        var id = String(edit.editId || '');
        var baseId = id.endsWith('_rev') ? id.slice(0, -4) : id;
        return !deletedSet.has(id) && !deletedSet.has(baseId) && !deletedSet.has(baseId + '_rev');
      });
      Object.keys(memoryChipStates || {}).forEach(function(k) {
        var base = k.endsWith('_rev') ? k.slice(0, -4) : k;
        if (deletedSet.has(k) || deletedSet.has(base) || deletedSet.has(base + '_rev')) {
          delete memoryChipStates[k];
        }
      });
      renderMemoryChips(userEditsState);
      rerenderAllOutputs();
    }

    window.addEventListener('storage', function(e) {
      if (e.key !== syncStorageKey || !e.newValue) return;
      try {
        var payload = JSON.parse(e.newValue);
        if (!payload || !payload.syncToken) return;
        if (payload.syncToken <= lastSyncToken) return;
        lastSyncToken = payload.syncToken;
        pruneDeletedMemory(payload);
      } catch (err) {}
    });

    function fetchReverseSourceWord(targetWord, targetLang) {
      return fetch('/api/reverse-word', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          target_word: targetWord,
          source_lang: currentSourceLang,
          target_lang: targetLang,
          source_text: srcText.value
        })
      }).then(function(r) { return r.json(); })
      .then(function(data) {
        return String((data && data.source_word) || '').trim();
      }).catch(function() {
        return '';
      });
    }

    function isLikelyResolvedSourceWord(sourceWord) {
      var val = String(sourceWord || '').trim();
      if (!val || val === '...') return false;
      if (currentSourceLang === 'en' && /[\u0600-\u06FF]/.test(val)) return false;
      var sourceNorm = normalizeForMatch(srcText.value || '');
      var candidateNorm = normalizeForMatch(val);
      if (!sourceNorm || !candidateNorm) return true;
      if (candidateNorm.length < 2) return true;
      return sourceNorm.indexOf(candidateNorm) !== -1;
    }

    window.openEditPopover = function(el) {
      currentEditWordEl = el;
      var rect = el.getBoundingClientRect();
      var containerRect = document.querySelector('.translate-container').getBoundingClientRect();
      
      var editId = el.getAttribute('data-edit-id');
      var googleWord = el.getAttribute('data-google');
      var sourceAttr = el.getAttribute('data-source');
      var sourceFixed = el.getAttribute('data-source-fixed') === '1';
      var savedWord = el.getAttribute('data-saved');
      var targetLang = el.getAttribute('data-lang');
      var clickedWord = el.textContent.trim();
      
      console.log('[DEBUG][popover] Opening for word:', clickedWord);
      console.log('[DEBUG][popover]   data-source:', sourceAttr, 'data-google:', googleWord, 'data-saved:', savedWord, 'data-edit-id:', editId);
      
      // Set up the popover inputs immediately
      document.getElementById('po-target-input').value = savedWord || googleWord || clickedWord;
      document.getElementById('po-target-lang').value = targetLang;
      document.getElementById('po-google-translation').value = googleWord;
      
      var savedArea = document.getElementById('po-saved-area');
      if (editId && savedWord) {
        savedArea.style.display = 'flex';
        document.getElementById('po-saved-word').textContent = savedWord;
      } else {
        savedArea.style.display = 'none';
      }

      // Position and show the popover
      editPopover.style.display = 'flex';
      var topPos = (rect.bottom - containerRect.top) + window.scrollY;
      var leftPos = (rect.left - containerRect.left) + (rect.width / 2);
      
      setTimeout(function() {
         editPopover.style.top = topPos + 'px';
         editPopover.style.left = leftPos + 'px';
         editPopover.classList.add('is-open');
         document.getElementById('po-target-input').focus();
      }, 10);
      
      event.stopPropagation();
      
      // Now resolve the correct SOURCE word
      pendingSourceResolve = null;
      if ((editId && sourceAttr) || (sourceFixed && sourceAttr)) {
        console.log('[DEBUG][popover] Using existing edit sourceWord:', sourceAttr);
        document.getElementById('po-source-word').textContent = sourceAttr;
        pendingSourceResolve = Promise.resolve(sourceAttr);
      } else {
        // No existing edit — need to figure out the SOURCE word for this TARGET word
        // Show loading state while resolving
        document.getElementById('po-source-word').textContent = '...';
        
        console.log('[DEBUG][popover] Resolving source word via reverse-word API...');
        pendingSourceResolve = fetchReverseSourceWord(googleWord || clickedWord, targetLang)
        .then(function(sourceWord) {
          var resolvedSource = sourceWord || googleWord || clickedWord;
          console.log('[DEBUG][popover] Resolved source word:', resolvedSource);
          document.getElementById('po-source-word').textContent = resolvedSource;
          // Also update the element's data-source for future reference
          if (currentEditWordEl) {
            currentEditWordEl.setAttribute('data-source', resolvedSource);
          }
          return resolvedSource;
        }).catch(function(err) {
          console.error('[DEBUG][popover] Reverse word error:', err.message);
          return '';
        });
      }
    };

    window.closeEditPopover = function() {
      editPopover.classList.remove('is-open');
      setTimeout(function() { editPopover.style.display = 'none'; }, 200);
      currentEditWordEl = null;
    };

    window.saveUserEdit = async function() {
      if (!currentEditWordEl) return;
      var newTranslation = document.getElementById('po-target-input').value.trim();
      if (!newTranslation) {
        closeEditPopover();
        return;
      }
      
      var sourceWord = document.getElementById('po-source-word').textContent;
      var targetLang = document.getElementById('po-target-lang').value;
      var originalGoogle = document.getElementById('po-google-translation').value;
      var fallbackTargetWord = originalGoogle || currentEditWordEl.textContent.trim();

      if (pendingSourceResolve) {
        try {
          var pendingResolved = await pendingSourceResolve;
          if (pendingResolved) {
            sourceWord = pendingResolved;
            document.getElementById('po-source-word').textContent = pendingResolved;
          }
        } catch (e) {}
      }

      if (!isLikelyResolvedSourceWord(sourceWord)) {
        var retryResolved = await fetchReverseSourceWord(fallbackTargetWord, targetLang);
        if (retryResolved) {
          sourceWord = retryResolved;
          document.getElementById('po-source-word').textContent = retryResolved;
        }
      }
      if (!isLikelyResolvedSourceWord(sourceWord)) {
        Toast.error('Could not resolve source word. Please try again.');
        return;
      }
      
      console.log('[DEBUG][saveUserEdit] ──── SAVING ────');
      console.log('[DEBUG][saveUserEdit] sourceWord:', sourceWord);
      console.log('[DEBUG][saveUserEdit] targetLang:', targetLang);
      console.log('[DEBUG][saveUserEdit] originalGoogle:', originalGoogle);
      console.log('[DEBUG][saveUserEdit] newTranslation:', newTranslation);
      console.log('[DEBUG][saveUserEdit] currentSourceLang:', currentSourceLang);
      
      api('/api/user-edit', {
        method: 'POST',
        body: JSON.stringify({
          source_word: sourceWord,
          source_lang: currentSourceLang,
          target_lang: targetLang,
          original_translation: originalGoogle,
          edited_translation: newTranslation
        })
      }).then(function(res) {
         console.log('[DEBUG][saveUserEdit] API response:', JSON.stringify(res));
         if (res.success && res.edit) {
           Toast.success('Edit saved to memory');
           
           var eid = res.edit._id || res.edit.id || Date.now().toString();
           
           // userEditsState is a FLAT ARRAY. Remove any older edit for the same sourceWord+targetLang.
           userEditsState = userEditsState.filter(function(e) {
             return !(e.sourceWord === res.edit.sourceWord && e.targetLanguage === targetLang);
           });
           
           // Add the newly saved edit to the flat array
           userEditsState.push({
             editId: eid,
             sourceWord: res.edit.sourceWord,
             targetLanguage: targetLang,
             userTranslation: res.edit.editedTranslation,
             googleTranslation: res.edit.originalTranslation || originalGoogle,
             usageCount: res.edit.usageCount || 1
           });
           
           console.log('[DEBUG][saveUserEdit] Updated userEditsState:', JSON.stringify(userEditsState.map(function(e) { return { src: e.sourceWord, user: e.userTranslation, lang: e.targetLanguage }; })));
           
           // Turn on the chip
           memoryChipStates[eid] = true;
           
           renderMemoryChips(userEditsState);
           rerenderAllOutputs();
         }
      }).catch(function(err) {
         console.error('[DEBUG][saveUserEdit] Error:', err.message);
         Toast.error('Failed to save edit: ' + err.message);
      });
      
      closeEditPopover();
    };
    
