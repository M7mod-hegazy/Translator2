    // Initialize
    syncTargetPills(); buildTargetPanels(); updateAcDirection();
    var stored = sessionStorage.getItem('loadSession');
    if (stored) {
      sessionStorage.removeItem('loadSession');
      try {
        var sess = JSON.parse(stored);
        if (sess.source_lang) setSourceLang(sess.source_lang);
        if (sess.translations) { activeTargets = Object.keys(sess.translations).filter(function(c) { return c !== currentSourceLang; }); syncTargetPills(); buildTargetPanels(); }
        if (sess.category_id) { catSelect.value = sess.category_id; catSelect.dispatchEvent(new Event('change')); }
        if (sess.source_text) { srcText.value = sess.source_text; srcText.dispatchEvent(new Event('input')); }
      } catch (e) { }
    }

    // ── Resize Handle Logic ──
    (function() {
      var handle = document.getElementById('panel-resize-handle');
      var sourcePanel = document.getElementById('source-panel');
      var panels = document.getElementById('translate-panels');
      if (!handle || !sourcePanel || !panels) return;
      
      var isResizing = false;
      var startY, startHeight;
      
      handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        isResizing = true;
        startY = e.clientY;
        startHeight = panels.offsetHeight;
        document.body.style.cursor = 'row-resize';
        document.body.style.userSelect = 'none';
        handle.classList.add('is-active');
      });
      
      document.addEventListener('mousemove', function(e) {
        if (!isResizing) return;
        var dy = e.clientY - startY;
        var newHeight = Math.max(200, startHeight + dy);
        panels.style.minHeight = newHeight + 'px';
      });
      
      document.addEventListener('mouseup', function() {
        if (isResizing) {
          isResizing = false;
          document.body.style.cursor = '';
          document.body.style.userSelect = '';
          handle.classList.remove('is-active');
        }
      });
      
      // Touch support
      handle.addEventListener('touchstart', function(e) {
        e.preventDefault();
        isResizing = true;
        startY = e.touches[0].clientY;
        startHeight = panels.offsetHeight;
        handle.classList.add('is-active');
      }, { passive: false });
      
      document.addEventListener('touchmove', function(e) {
        if (!isResizing) return;
        var dy = e.touches[0].clientY - startY;
        var newHeight = Math.max(200, startHeight + dy);
        panels.style.minHeight = newHeight + 'px';
      });
      
      document.addEventListener('touchend', function() {
        if (isResizing) {
          isResizing = false;
          handle.classList.remove('is-active');
        }
      });
    })();
  </script>
</body>
</html>
