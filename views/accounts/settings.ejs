<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings — ORBIS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
</head>
<body>
  <%- include('../partials/sidebar.ejs') %>
  
  <main class="main-content">
    <div class="address-bar">
      <div class="address-bar-item">
        <i data-lucide="home" style="width:12px;height:12px;"></i>
        <span>Main</span>
      </div>
      <span class="address-bar-sep">/</span>
      <div class="address-bar-item">
        <span>Settings</span>
      </div>
    </div>
    
    <header class="page-header">
      <div class="page-header-left">
        <h1 class="page-title">Settings</h1>
      </div>
    </header>

    <div class="page-body">
      <div class="card">
        <div class="card-header">
          <h3>Application Settings</h3>
        </div>
        <div class="card-body">
          <form id="settings-form">
            <div class="form-group">
              <label class="form-label">Default Source Language</label>
              <select class="form-select" name="preferredSourceLang" id="source-lang">
                <option value="en">English</option>
                <option value="ar">Arabic</option>
                <option value="es">Spanish</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Default Target Language</label>
              <select class="form-select" name="preferredTargetLang" id="target-lang">
                <option value="ar">Arabic</option>
                <option value="en">English</option>
                <option value="es">Spanish</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/app.js"></script>
  <script>
    lucide.createIcons();
    
    document.getElementById('settings-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      Toast.success('Settings saved successfully');
    });
  </script>
</body>
</html>
