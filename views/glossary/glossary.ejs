<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categories — ORBIS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <style>
    .gloss-layout { display: grid; grid-template-columns: 260px 1fr; gap: var(--space-lg); min-height: 500px; }
    .gloss-cats { padding: var(--space-md); overflow-y: auto; }
    .gloss-cats-label { font-size: var(--text-xs); font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; padding: var(--space-sm); margin-bottom: var(--space-sm); }
    .gloss-terms { padding: 0; }
    .gloss-terms-head { display: flex; align-items: center; justify-content: space-between; padding: var(--space-md) var(--space-lg); border-bottom: 1px solid var(--gold-border); }
    .gloss-terms-head h3 { font-size: var(--text-lg); font-weight: 600; margin: 0; }
    .cat-row { display: flex; align-items: center; border-radius: var(--radius-md); transition: background .15s; margin-bottom: 2px; }
    .cat-row:hover { background: rgba(212, 175, 55, 0.06); }
    .cat-row.is-active { background: rgba(212, 175, 55, 0.10); border-left: 3px solid var(--gold-400); }
    .cat-row-main { flex: 1; display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; cursor: pointer; min-width: 0; }
    .cat-row-name { font-size: var(--text-sm); color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .global-search-container { position: relative; margin-bottom: var(--space-lg); }
    .global-search-bar { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--bg-card); border: 1px solid var(--gold-border); border-radius: var(--radius-lg); transition: border-color .2s, box-shadow .2s; }
    .global-search-bar:focus-within { border-color: var(--gold-border-bright); box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.08); }
    .gs-icon { width: 16px; height: 16px; color: var(--text-muted); flex-shrink: 0; }
    .gs-input { flex: 1; background: transparent; border: none; outline: none; color: var(--text-primary); font-size: 14px; font-family: var(--font-ui); }
    .gs-input::placeholder { color: var(--text-muted); }
    .gs-kbd { font-size: 11px; padding: 2px 8px; border-radius: 4px; background: rgba(255, 255, 255, 0.06); color: var(--text-muted); border: 1px solid var(--gold-border); cursor: pointer; font-family: inherit; }
    .gs-kbd:hover { background: rgba(255, 255, 255, 0.12); color: var(--text-primary); }
    .gs-dropdown { position: absolute; inset-inline: 0; top: 100%; margin-top: 4px; background: var(--bg-card); border: 1px solid var(--gold-border); border-radius: var(--radius-lg); max-height: 320px; overflow-y: auto; z-index: 100; box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35); }
    .gs-results { padding: 6px; }
    .gs-result-row { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 12px; align-items: center; padding: 8px 12px; border-radius: var(--radius-md); cursor: pointer; transition: background .15s; font-size: 13px; }
    .gs-result-row:hover { background: rgba(212, 175, 55, 0.08); }
    .gs-result-term { color: var(--text-primary); font-weight: 500; }
    .gs-result-term[dir="rtl"] { text-align: right; }
    .gs-cat-badge { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; background: rgba(212, 175, 55, 0.12); color: var(--gold-400); white-space: nowrap; text-align: center; }
    .gs-no-results { padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px; }
    .gs-result-row mark { background: rgba(212, 175, 55, 0.25); color: inherit; border-radius: 2px; padding: 0 1px; }
    /* Category-internal search/filter/sort */
    .terms-toolbar {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      background: rgba(255, 255, 255, 0.02);
      border-bottom: 1px solid var(--gold-border);
    }
    .terms-search {
      flex: 1;
      position: relative;
      display: flex;
      align-items: center;
    }
    .terms-search input {
      width: 100%;
      padding: 10px 14px 10px 40px;
      background: rgba(10, 10, 14, 0.4);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 12px;
      font-size: 14px;
      color: var(--text-primary);
      outline: none;
      transition: all 0.2s;
    }
    .terms-search input:focus {
      border-color: var(--gold-400);
      background: rgba(10, 10, 14, 0.6);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
    }
    .terms-search i {
      position: absolute;
      left: 14px;
      color: var(--gold-400);
      width: 16px;
      height: 16px;
      opacity: 0.7;
      pointer-events: none;
    }
    .terms-sort {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .terms-sort label {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
    }
    .terms-sort select {
      padding: 8px 12px;
      background: rgba(10, 10, 14, 0.4);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 10px;
      font-size: 13px;
      color: var(--text-primary);
      outline: none;
      cursor: pointer;
      transition: all 0.2s;
    }
    .terms-sort select:hover {
      border-color: var(--gold-400);
    }
    .terms-count {
      font-size: 11px;
      font-weight: 600;
      color: var(--gold-400);
      padding: 4px 10px;
      background: rgba(212, 175, 55, 0.1);
      border: 1px solid rgba(212, 175, 55, 0.15);
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Term Card Design */
    .term-card-grid {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 4px;
    }
    .term-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(212, 175, 55, 0.1);
      border-radius: 14px;
      padding: 16px 20px;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 20px;
      align-items: center;
      transition: all 0.2s ease;
    }
    .term-card:hover {
      background: rgba(212, 175, 55, 0.04);
      border-color: rgba(212, 175, 55, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }
    .term-lang-group {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .lang-indicator {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.05);
      font-size: 10px;
      font-weight: 800;
      color: var(--text-muted);
      flex-shrink: 0;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .lang-indicator.en { color: #60a5fa; background: rgba(96, 165, 250, 0.1); border-color: rgba(96, 165, 250, 0.15); }
    .lang-indicator.ar { color: #34d399; background: rgba(52, 211, 153, 0.1); border-color: rgba(52, 211, 153, 0.15); }
    .lang-indicator.es { color: #f87171; background: rgba(248, 113, 113, 0.1); border-color: rgba(248, 113, 113, 0.15); }
    
    .term-text {
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .term-text[dir="rtl"] {
      font-size: 16px;
      font-family: inherit;
    }
    .admin-edit-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: all 0.2s;
    }
    .admin-edit-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }
    .preview-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: rgba(212, 175, 55, 0.12);
      color: var(--gold-400);
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }
    @media (max-width: 768px) {
      .gloss-layout { 
        grid-template-columns: 1fr; 
        gap: 16px; 
      }
      .gloss-cats { 
        max-height: 180px; 
        overflow-y: auto; 
        padding: 12px;
      }
      .gloss-terms { 
        width: 100%; 
      }
      .cat-row { 
        margin-bottom: 4px;
      }
      .cat-row-main {
        padding: 10px 12px;
      }
      .cat-row-name {
        font-size: 14px;
      }
      .gloss-cats-label {
        padding: 12px;
        font-size: 11px;
      }
      .global-search-container { 
        margin-bottom: 16px; 
      }
      .global-search-bar {
        padding: 10px 12px;
      }
      .gs-input { 
        font-size: 14px; 
      }
      .gs-dropdown { 
        max-height: 250px; 
      }
      .gs-result-row {
        grid-template-columns: 1fr;
        gap: 4px;
        padding: 10px 12px;
      }
      .gs-cat-badge {
        justify-self: start;
      }
      .page-header { 
        flex-wrap: wrap; 
        gap: 12px; 
        padding: 16px;
      }
      .page-title {
        font-size: 20px;
      }
      .page-header-right { 
        width: 100%; 
        display: flex; 
        gap: 8px; 
      }
      .page-header-right .btn,
      .admin-edit-btn { 
        flex: 1; 
        justify-content: center; 
        padding: 10px 12px;
        font-size: 12px;
      }
      .preview-badge {
        font-size: 10px;
      }
      .terms-toolbar {
        flex-wrap: wrap;
        gap: 12px;
        padding: 12px 16px;
      }
      .terms-search {
        min-width: 100%;
        order: 1;
      }
      .terms-search input {
        padding: 10px 12px 10px 36px;
      }
      .terms-sort {
        order: 2;
      }
      .terms-count {
        order: 3;
        margin-left: auto;
      }
      .term-card {
        grid-template-columns: 1fr;
        gap: 10px;
        padding: 14px 16px;
      }
      .term-lang-group {
        gap: 10px;
      }
      .lang-indicator {
        width: 22px;
        height: 22px;
        font-size: 9px;
      }
      .term-text {
        font-size: 14px;
      }
      .gloss-terms-head {
        padding: 14px 16px;
      }
      .gloss-terms-head h3 {
        font-size: 16px;
      }
    }
    @media (max-width: 480px) {
      .gloss-cats { 
        max-height: 140px; 
        padding: 10px;
      }
      .cat-row-main {
        padding: 8px 10px;
      }
      .cat-row-name { 
        font-size: 13px; 
      }
      .gloss-cats-label {
        padding: 10px;
        font-size: 10px;
      }
      .nav-item-badge {
        font-size: 10px;
        padding: 2px 6px;
      }
      .page-title {
        font-size: 18px;
      }
      .preview-badge {
        font-size: 9px;
      }
      .admin-edit-btn {
        font-size: 11px;
        padding: 8px 10px;
      }
      .term-card {
        padding: 12px 14px;
      }
      .term-lang-group {
        gap: 8px;
      }
      .lang-indicator {
        width: 20px;
        height: 20px;
        font-size: 8px;
      }
      .term-text {
        font-size: 13px;
      }
      .term-text[dir="rtl"] {
        font-size: 14px;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/home-mobile-header.ejs', { user: typeof user !== 'undefined' ? user : null }) %>
  <%- include('../partials/sidebar.ejs', { activeTab: 'glossary', user: user }) %>
  <div class="app-shell">
    <main class="main-content">
    <header class="page-header">
      <div class="page-header-left">
        <h1 class="page-title">Categories</h1>
        <span class="preview-badge"><i data-lucide="eye" style="width:12px;height:12px;"></i> Preview Mode</span>
      </div>
      <div class="page-header-right">
        <% if (user && user.role === 'admin') { %>
        <a href="/admin/glossary" class="admin-edit-btn">
          <i data-lucide="settings" style="width:14px;height:14px;"></i> Edit in Admin
        </a>
        <% } %>
      </div>
    </header>

    <div class="page-body">
      <div class="gloss-layout">
        <div class="card gloss-cats">
          <div class="gloss-cats-label">Categories</div>
          <div id="category-list">
            <% (categories || []).forEach(function(cat) { %>
            <div class="cat-row" data-cat-id="<%= cat._id %>">
              <div class="cat-row-main" onclick="selectCategory('<%= cat._id %>','<%= cat.name %>')">
                <span class="cat-row-name"><%= cat.name %></span>
                <span class="nav-item-badge"><%= cat.termCount || 0 %></span>
              </div>
            </div>
            <% }); %>
            <% if (!categories || categories.length === 0) { %>
            <div class="text-muted" style="padding:var(--space-md);font-size:var(--text-sm);text-align:center;">No categories yet.</div>
            <% } %>
          </div>
        </div>
        <div class="card gloss-terms">
          <div class="gloss-terms-head">
            <h3 id="terms-title"><%= (categories && categories[0]) ? categories[0].name : 'Select a category' %></h3>
          </div>
          <div class="terms-toolbar">
            <div class="terms-search">
              <i data-lucide="search"></i>
              <input type="text" id="terms-search-input" placeholder="Search in category...">
            </div>
            <div class="terms-sort">
              <label>Sort:</label>
              <select id="terms-sort-select">
                <option value="en-asc">English A-Z</option>
                <option value="en-desc">English Z-A</option>
                <option value="ar-asc">Arabic A-Z</option>
                <option value="ar-desc">Arabic Z-A</option>
                <option value="es-asc">Spanish A-Z</option>
                <option value="es-desc">Spanish Z-A</option>
              </select>
            </div>
            <span class="terms-count" id="terms-count">0 terms</span>
          </div>
          <div id="terms-container" style="padding:var(--space-md);">
            <div id="terms-loading" style="display:none;" class="page-loader">
              <div class="spinner"></div>
            </div>
            <table class="data-table" id="terms-table" style="display:none;">
              <thead>
                <tr>
                  <th>English</th>
                  <th style="text-align:right;">Arabic</th>
                  <th>Spanish</th>
                </tr>
              </thead>
              <tbody id="terms-body"></tbody>
            </table>
            <div id="terms-empty" class="empty-state" style="display:none;">
              <div class="empty-state-icon">📖</div>
              <div class="empty-state-title">No terms in this category</div>
              <div class="empty-state-text">This category is empty.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  </div>

  <script src="/js/app.js?v=2"></script>
  <script>
    lucide.createIcons();
    
    var activeCategoryId = document.querySelector('.cat-row') ? document.querySelector('.cat-row').dataset.catId : null;
    if (activeCategoryId) { loadTerms(activeCategoryId); document.querySelector('.cat-row').classList.add('is-active'); }

    function selectCategory(id, name) {
      activeCategoryId = id;
      document.getElementById('terms-title').textContent = name;
      document.querySelectorAll('.cat-row').forEach(function(el) { el.classList.toggle('is-active', el.dataset.catId === id); });
      loadTerms(id);
    }

    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    var allTerms = [];
    var currentSort = 'en-asc';
    var currentSearch = '';

    function loadTerms(catId) {
      var loadingEl = document.getElementById('terms-loading');
      var tableEl = document.getElementById('terms-table');
      var emptyEl = document.getElementById('terms-empty');
      var searchInput = document.getElementById('terms-search-input');
      
      if (loadingEl) loadingEl.style.display = 'flex';
      if (tableEl) tableEl.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'none';
      if (searchInput) searchInput.value = '';
      currentSearch = '';
      
      api('/glossary/term?category_id=' + catId).then(function(res) {
        allTerms = res.terms || [];
        renderTerms();
        if (loadingEl) loadingEl.style.display = 'none';
      }).catch(function() { 
        Toast.error('Failed to load terms.'); 
        if (loadingEl) loadingEl.style.display = 'none';
      });
    }

    function renderTerms() {
      var container = document.getElementById('terms-container');
      var terms = allTerms.slice();
      
      // Filter by search
      if (currentSearch) {
        var q = currentSearch.toLowerCase();
        terms = terms.filter(function(t) {
          return (t.term_en || '').toLowerCase().includes(q) ||
                 (t.term_ar || '').toLowerCase().includes(q) ||
                 (t.term_es || '').toLowerCase().includes(q);
        });
      }
      
      // Sort
      var sortField = currentSort.split('-')[0];
      var sortDir = currentSort.split('-')[1];
      var fieldMap = { en: 'term_en', ar: 'term_ar', es: 'term_es' };
      terms.sort(function(a, b) {
        var va = (a[fieldMap[sortField]] || '').toLowerCase();
        var vb = (b[fieldMap[sortField]] || '').toLowerCase();
        if (sortDir === 'desc') { var tmp = va; va = vb; vb = tmp; }
        return va.localeCompare(vb);
      });
      
      // Update count
      var countEl = document.getElementById('terms-count');
      if (countEl) countEl.textContent = terms.length + ' term' + (terms.length !== 1 ? 's' : '');
      
      if (terms.length) {
        var html = '<div class="term-card-grid">';
        html += terms.map(function(t) {
          return '<div class="term-card">'
            + '<div class="term-lang-group">'
              + '<span class="lang-indicator en">EN</span>'
              + '<span class="term-text">' + esc(t.term_en || '\u2014') + '</span>'
            + '</div>'
            + '<div class="term-lang-group">'
              + '<span class="lang-indicator ar">AR</span>'
              + '<span class="term-text" dir="rtl">' + esc(t.term_ar || '\u2014') + '</span>'
            + '</div>'
            + '<div class="term-lang-group">'
              + '<span class="lang-indicator es">ES</span>'
              + '<span class="term-text">' + esc(t.term_es || '\u2014') + '</span>'
            + '</div>'
            + '</div>';
        }).join('');
        html += '</div>';
        
        container.innerHTML = html;
        lucide.createIcons();
      } else {
        container.innerHTML = '<div id="terms-empty" class="empty-state" style="display:flex;">'
          + '<div class="empty-state-icon">📖</div>'
          + '<div class="empty-state-title">No terms found</div>'
          + '<div class="empty-state-text">' + (currentSearch ? 'No terms match your search.' : 'This category is empty.') + '</div>'
          + '</div>';
      }
    }

    // Terms search input
    var termsSearchInput = document.getElementById('terms-search-input');
    if (termsSearchInput) {
      termsSearchInput.addEventListener('input', function() {
        currentSearch = this.value.trim();
        renderTerms();
      });
    }

    // Terms sort select
    var termsSortSelect = document.getElementById('terms-sort-select');
    if (termsSortSelect) {
      termsSortSelect.addEventListener('change', function() {
        currentSort = this.value;
        renderTerms();
      });
    }

    document.addEventListener('click', function(e) {
      // No global search to handle
    });
  </script>
</body>
</html>
