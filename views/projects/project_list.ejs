<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>History — Translator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <style>
    /* Header */
    .hist-header { flex-direction: column !important; gap: var(--space-sm) !important; align-items: stretch !important; }
    .hist-header-top { display: flex; align-items: center; justify-content: space-between; width: 100%; }

    /* Search Bar */
    .history-search-bar { position: relative; width: 100%; }
    .history-search-input { width: 100%; padding: 11px 40px 11px 40px; font-size: 14px; background: var(--bg-card); border: 1px solid var(--gold-border); border-radius: var(--radius-lg); color: var(--text-primary); transition: all .25s; box-sizing: border-box; }
    .history-search-input:focus { border-color: var(--gold-400); box-shadow: 0 0 0 3px rgba(212,175,55,0.12); outline: none; }
    .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: var(--text-muted); pointer-events: none; }
    .search-clear { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px; border-radius: 50%; transition: all .2s; }
    .search-clear:hover { color: var(--text-primary); background: rgba(255,255,255,0.06); }
    .search-spinner { position: absolute; right: 40px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; border: 2px solid var(--gold-border); border-top-color: var(--gold-400); border-radius: 50%; animation: spin .6s linear infinite; }
    @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }
    .history-count { font-size: 12px; color: var(--text-muted); white-space: nowrap; }

    /* Grid */
    .sessions-grid { display: grid; grid-template-columns: repeat(auto-fill ; gap: var(--space-md); }

    /* Card */
    .session-card { background: var(--bg-card); border: 1px solid rgba(212,175,55,0.08); border-radius: var(--radius-lg); display: flex; flex-direction: column; justify-content: space-between; overflow: hidden; cursor: pointer; transition: all .3s cubic-bezier(.4,0,.2,1); animation: cardIn .45s var(--ease-out) both; position: relative; }
    .session-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(135deg,rgba(212,175,55,0.05) 0%,transparent 60%); opacity: 0; transition: opacity .3s; pointer-events: none; }
    .session-card:hover { border-color: rgba(212,175,55,0.3); transform: translateY(-4px) scale(1.01); box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 0 1px rgba(212,175,55,0.12), inset 0 1px 0 rgba(212,175,55,0.06); }
    .session-card:hover::before { opacity: 1; }
    .session-card:active { transform: translateY(-1px) scale(0.99); transition-duration: .1s; }

    @keyframes cardIn { from { opacity: 0; transform: translateY(18px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .session-card:nth-child(2) { animation-delay: .04s; }
    .session-card:nth-child(3) { animation-delay: .08s; }
    .session-card:nth-child(4) { animation-delay: .12s; }
    .session-card:nth-child(5) { animation-delay: .16s; }
    .session-card:nth-child(6) { animation-delay: .2s; }
    .session-card:nth-child(n+7) { animation-delay: .24s; }

    .card-top { padding: 16px 16px 12px; }
    .card-title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .card-title { font-size: 13px; font-weight: 600; color: var(--text-primary); line-height: 1.35; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: calc(100% - 60px); }
    .card-actions { display: flex; gap: 2px; opacity: 0; transition: opacity .2s; }
    .session-card:hover .card-actions { opacity: 1; }
    .card-action-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 5px; border-radius: var(--radius-sm); transition: all .15s; display: flex; align-items: center; justify-content: center; }
    .card-action-btn.load-btn:hover { color: var(--gold-400); background: rgba(212,175,55,0.1); }
    .card-action-btn.del-btn:hover { color: #e55; background: rgba(238,85,85,0.08); }

    .card-source { font-size: 12px; color: var(--text-secondary); line-height: 1.55; margin: 0 0 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-translation { font-size: 11px; color: var(--gold-400); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; opacity: .85; }
    .card-trans-label { font-weight: 700; font-size: 9px; text-transform: uppercase; background: rgba(212,175,55,0.12); padding: 1px 5px; border-radius: 3px; margin-right: 4px; letter-spacing: .5px; }

    .card-bottom { padding: 10px 16px; border-top: 1px solid rgba(212,175,55,0.06); display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.08); }
    .card-meta { display: flex; align-items: center; gap: 5px; font-size: 10px; color: var(--text-muted); flex-wrap: wrap; }
    .card-meta-item { display: flex; align-items: center; gap: 3px; white-space: nowrap; }
    .card-meta-dot { color: rgba(212,175,55,0.2); }
    .card-langs { display: flex; gap: 3px; flex-wrap: wrap; }
    .card-lang-pill { padding: 2px 7px; font-size: 9px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-pill); background: rgba(212,175,55,0.08); color: var(--gold-400); border: 1px solid rgba(212,175,55,0.12); letter-spacing: .3px; }

    mark.hl { background: rgba(212,175,55,0.3); color: var(--text-primary); border-radius: 2px; padding: 0 1px; }

    /* Pagination */
    .pagination-nav { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: var(--space-lg); padding: var(--space-md) 0; }
    .pg-pages { display: flex; align-items: center; gap: 4px; }
    .pg-btn { display: inline-flex; align-items: center; gap: 4px; padding: 7px 13px; font-size: 12px; font-weight: 500; color: var(--text-secondary); background: var(--bg-card); border: 1px solid var(--gold-border); border-radius: var(--radius-md); text-decoration: none; transition: all .2s; cursor: pointer; }
    .pg-btn:hover { border-color: var(--gold-400); color: var(--gold-400); background: rgba(212,175,55,0.06); }
    .pg-btn.is-active { background: rgba(212,175,55,0.15); border-color: var(--gold-400); color: var(--gold-400); font-weight: 700; }
    .pg-dots { color: var(--text-muted); padding: 0 4px; font-size: 12px; }

    .search-status { grid-column: 1/-1; text-align: center; padding: var(--space-lg); font-size: 13px; color: var(--text-muted); }

    /* Hero Expand */
    .hero-overlay { position: fixed; inset: 0; z-index: 9999; pointer-events: none; opacity: 0; background: radial-gradient(circle at var(--hx,50%) var(--hy,50%),rgba(212,175,55,0.06) 0%,rgba(8,10,18,0.98) 70%); transition: opacity .5s cubic-bezier(.4,0,.2,1); }
    .hero-overlay.is-active { opacity: 1; pointer-events: all; }

    .hero-clone { position: fixed; z-index: 10000; border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 20px 80px rgba(0,0,0,0.6), 0 0 60px rgba(212,175,55,0.08); transition: all .6s cubic-bezier(.4,0,.12,1); will-change: transform,top,left,width,height,border-radius; }
    .hero-clone.is-expanding { top: 0 !important; left: 0 !important; width: 100vw !important; height: 100vh !important; border-radius: 0 !important; }

    .hero-reveal { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 40px 40px; opacity: 0; transition: opacity .3s .4s; overflow: hidden; }
    .hero-clone.is-expanding .hero-reveal { opacity: 1; }

    .hero-source-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); margin-bottom: 12px; opacity: 0; transform: translateY(10px); transition: all .4s .6s cubic-bezier(.4,0,.2,1); }
    .hero-clone.phase-2 .hero-source-label { opacity: 1; transform: translateY(0); }

    .hero-source-text { font-size: 20px; font-weight: 400; color: var(--text-primary); line-height: 1.6; max-width: 640px; text-align: center; word-break: break-word; min-height: 60px; border-right: 2px solid var(--gold-400); padding-right: 4px; animation: blink .6s step-end infinite; }
    .hero-source-text.done { border-right-color: transparent; animation: none; }
    @keyframes blink { 50% { border-right-color: transparent; } }

    .hero-divider { width: 0; height: 2px; margin: 24px 0; background: linear-gradient(90deg,transparent,var(--gold-400),transparent); transition: width .5s 0s cubic-bezier(.4,0,.2,1); border-radius: 2px; }
    .hero-clone.phase-3 .hero-divider { width: 120px; }

    .hero-trans-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; padding: 3px 10px; border-radius: var(--radius-pill); background: rgba(212,175,55,0.12); color: var(--gold-400); margin-bottom: 10px; opacity: 0; transform: translateX(30px); transition: all .4s .15s cubic-bezier(.4,0,.2,1); }
    .hero-clone.phase-3 .hero-trans-label { opacity: 1; transform: translateX(0); }

    .hero-trans-text { font-size: 18px; color: var(--gold-400); line-height: 1.5; max-width: 640px; text-align: center; word-break: break-word; opacity: 0; transform: translateX(40px); transition: all .5s .25s cubic-bezier(.4,0,.2,1); }
    .hero-clone.phase-3 .hero-trans-text { opacity: 1; transform: translateX(0); }

    .hero-pills { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; justify-content: center; }
    .hero-pill { padding: 5px 14px; font-size: 11px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-pill); background: rgba(212,175,55,0.1); color: var(--gold-400); border: 1px solid rgba(212,175,55,0.2); opacity: 0; transform: scale(0.3) translateY(20px); transition: all .35s cubic-bezier(.34,1.56,.64,1); }
    .hero-clone.phase-4 .hero-pill { opacity: 1; transform: scale(1) translateY(0); }
    .hero-clone.phase-4 .hero-pill:nth-child(2) { transition-delay: .08s; }
    .hero-clone.phase-4 .hero-pill:nth-child(3) { transition-delay: .16s; }
    .hero-clone.phase-4 .hero-pill:nth-child(4) { transition-delay: .24s; }

    .hero-bottom { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 40px 28px; display: flex; flex-direction: column; align-items: center; }
    .hero-progress-track { width: 200px; height: 3px; border-radius: 2px; background: rgba(212,175,55,0.1); overflow: hidden; margin-bottom: 12px; opacity: 0; transition: opacity .3s; }
    .hero-clone.phase-5 .hero-progress-track { opacity: 1; }
    .hero-progress-fill { height: 100%; width: 0; border-radius: 2px; background: linear-gradient(90deg,var(--gold-400),#f0d060); transition: width 1s cubic-bezier(.4,0,.2,1); }
    .hero-clone.phase-5 .hero-progress-fill { width: 100%; }
    .hero-status-label { font-size: 12px; color: var(--text-muted); letter-spacing: .5px; opacity: 0; transform: translateY(8px); transition: all .3s .1s; }
    .hero-clone.phase-5 .hero-status-label { opacity: 1; transform: translateY(0); }

    .sessions-grid.is-scattering .session-card { transition: all .45s cubic-bezier(.4,0,.2,1); opacity: 0; transform: scale(0.88) translateY(16px); filter: blur(2px); }
    .sessions-grid.is-scattering .session-card.is-hero { opacity: 1; transform: none; filter: none; }

    @media (max-width: 768px) {
      .hero-reveal { padding: 40px 20px 30px; }
      .hero-source-text { font-size: 15px; min-height: 40px; }
      .hero-trans-text { font-size: 14px; }
      .hero-source-label { font-size: 9px; }
      .hero-trans-label { font-size: 8px; }
      .hero-pill { font-size: 9px; padding: 4px 10px; }
      .hero-bottom { padding: 16px 20px 22px; }
      .hero-progress-track { width: 150px; }
      .hero-status-label { font-size: 10px; }
      .hist-header { padding: var(--space-sm) var(--space-md) !important; display: flex !important; flex-direction: column !important; gap: 8px !important; }
      .history-search-bar { display: block !important; width: 100% !important; min-height: 40px; }
      .history-search-input { font-size: 13px !important; padding: 9px 36px 9px 36px !important; display: block !important; width: 100% !important; box-sizing: border-box !important; }
      .search-icon { width: 13px; height: 13px; left: 12px; }
      .sessions-grid { gap: 8px; }
      .session-card { border-radius: var(--radius-md); }
      .card-top { padding: 12px 10px 8px; }
      .card-title { font-size: 11px; max-width: calc(100% - 26px); }
      .card-actions { opacity: 1; gap: 0; }
      .card-action-btn { padding: 3px; }
      .card-action-btn.del-btn { display: none; }
      .card-source { font-size: 10px; -webkit-line-clamp: 2; margin-bottom: 4px; }
      .card-translation { font-size: 9px; }
      .card-trans-label { font-size: 7px; padding: 1px 3px; }
      .card-bottom { padding: 6px 10px; flex-direction: column; align-items: flex-start; gap: 3px; }
      .card-meta { font-size: 9px; gap: 3px; }
      .card-meta-item i { display: none; }
      .card-langs { gap: 2px; }
      .card-lang-pill { font-size: 7px; padding: 1px 4px; }
      .pagination-nav { gap: 4px; flex-wrap: wrap; }
      .pg-btn { padding: 6px 10px; font-size: 11px; }
    }

    @media (max-width: 420px) {
      .sessions-grid { gap: 6px; }
      .card-top { padding: 10px 8px 6px; }
      .card-title { font-size: 10px; }
      .card-source { font-size: 9px; -webkit-line-clamp: 2; }
      .card-translation { display: none; }
      .card-bottom { padding: 5px 8px; }
      .card-meta { font-size: 8px; }
    }
  </style>
</head>
<body>
  <%- include('../partials/home-mobile-header.ejs', { user: typeof user !== 'undefined' ? user : null }) %>
  <%- include('../partials/sidebar.ejs', { activeTab: 'history', user: user }) %>
  <div class="app-shell">
    <main class="main-content">
    
    
    <header class="page-header hist-header">
      <div class="hist-header-top">
        <h1 class="page-title" style="margin:0;">Translation History</h1>
        <span id="result-count" class="history-count"><%= (sessions || []).length %> saved</span>
      </div>
      <div class="history-search-bar">
        <i data-lucide="search" class="search-icon"></i>
        <input type="text" id="live-search" class="history-search-input" placeholder="Search source text, translations, or titles..." value="<%= query || '' %>" autocomplete="off">
        <span id="search-spinner" class="search-spinner" style="display:none;"></span>
        <button id="search-clear" class="search-clear" style="display:none;" title="Clear search">
          <i data-lucide="x" style="width:14px;height:14px;"></i>
        </button>
      </div>
    </header>

    <div class="page-body">
      <!-- Hero Expand Overlay -->
      <div id="hero-overlay" class="hero-overlay"></div>

      <div id="sessions-grid" class="sessions-grid">
        <% (sessions || []).forEach(function(s) { %>
        <div class="session-card" data-id="<%= s._id %>" onclick="heroExpand('<%= s._id %>',this)">
          <div class="card-top">
            <div class="card-title-row">
              <h3 class="card-title"><%= s.title || 'Untitled' %></h3>
              <div class="card-actions">
                <button class="card-action-btn load-btn" onclick="event.stopPropagation();heroExpand('<%= s._id %>',this.closest('.session-card'))" title="Open">
                  <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </button>
                <button class="card-action-btn del-btn" onclick="event.stopPropagation();deleteSession('<%= s._id %>',this)" title="Delete">
                  <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
              </div>
            </div>
            <p class="card-source"><%= (s.sourceText || '').substring(0, 120) %><%= (s.sourceText || '').length > 120 ? '…' : '' %></p>
            <% var trans = s.translations || {}; var codes = Object.keys(trans); if (codes.length) { var firstCode = codes[0]; %>
            <p class="card-translation"><span class="card-trans-label"><%= firstCode.toUpperCase() %></span> <%= (trans[firstCode] || '').substring(0, 90) %><%= (trans[firstCode] || '').length > 90 ? '…' : '' %></p>
            <% } %>
          </div>
          <div class="card-bottom">
            <div class="card-meta">
              <span class="card-meta-item"><i data-lucide="languages" style="width:11px;height:11px;"></i> <%= s.sourceLanguage?.name || s.sourceLang || 'Source' %></span>
              <span class="card-meta-dot">·</span>
              <span class="card-meta-item"><%= s.wordCount || 0 %>w</span>
              <span class="card-meta-dot">·</span>
              <span class="card-meta-item"><i data-lucide="clock" style="width:11px;height:11px;"></i> <%= s.timeAgo || 'recently' %></span>
            </div>
            <% if (codes && codes.length) { %>
            <div class="card-langs">
              <% codes.forEach(function(code) { %>
              <span class="card-lang-pill"><%= code %></span>
              <% }); %>
            </div>
            <% } %>
          </div>
        </div>
        <% }); %>
        <% if (!sessions || sessions.length === 0) { %>
        <div class="empty-state" id="empty-state">
          <div class="empty-state-icon"><i data-lucide="history" style="width:48px;height:48px;color:var(--gold-400);opacity:0.5;"></i></div>
          <h3 class="empty-state-heading">No saved translations</h3>
          <p class="empty-state-text">Translate text on the home page — it auto-saves here.</p>
          <a href="/" class="btn btn-primary">Start Translating</a>
        </div>
        <% } %>
      </div>

      <% if (totalPages > 1) { %>
      <nav class="pagination-nav" id="pagination-nav">
        <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %><%= query ? '&q=' + query : '' %>" class="pg-btn">
          <i data-lucide="chevron-left" style="width:14px;height:14px;"></i> Prev
        </a>
        <% } %>
        <div class="pg-pages">
          <% for (var i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
          <span class="pg-btn is-active"><%= i %></span>
          <% } else if (i > currentPage - 3 && i < currentPage + 3) { %>
          <a href="?page=<%= i %><%= query ? '&q=' + query : '' %>" class="pg-btn"><%= i %></a>
          <% } else if (i === 1 || i === totalPages) { %>
          <a href="?page=<%= i %><%= query ? '&q=' + query : '' %>" class="pg-btn"><%= i %></a>
          <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
          <span class="pg-dots">…</span>
          <% } %>
          <% } %>
        </div>
        <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %><%= query ? '&q=' + query : '' %>" class="pg-btn">
          Next <i data-lucide="chevron-right" style="width:14px;height:14px;"></i>
        </a>
        <% } %>
      </nav>
      <% } %>
    </div>
  </main>
  </div>

  <script src="/js/app.js?v=2"></script>
  <script>
    (function() {
      var searchInput = document.getElementById('live-search');
      var grid = document.getElementById('sessions-grid');
      var pagNav = document.getElementById('pagination-nav');
      var clearBtn = document.getElementById('search-clear');
      var spinner = document.getElementById('search-spinner');
      var countEl = document.getElementById('result-count');
      var overlay = document.getElementById('hero-overlay');
      var timer = null;

      var originalGridHTML = grid.innerHTML;
      var originalPagHTML = pagNav ? pagNav.innerHTML : '';
      var originalPagDisplay = pagNav ? pagNav.style.display : '';

      function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
      function hl(text, q) { if (!q || !text) return esc(text || ''); var e = esc(text); var qe = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); return e.replace(new RegExp('(' + qe + ')', 'gi'), '<mark class="hl">$1</mark>'); }
      function trunc(s, n) { if (!s) return ''; return s.length > n ? s.substring(0, n) + '…' : s; }

      function restoreOriginal() {
        grid.innerHTML = originalGridHTML;
        if (pagNav) { pagNav.innerHTML = originalPagHTML; pagNav.style.display = originalPagDisplay; }
        countEl.textContent = '<%= (sessions || []).length %> saved';
        lucide.createIcons();
      }

      clearBtn.addEventListener('click', function() {
        searchInput.value = '';
        clearBtn.style.display = 'none';
        restoreOriginal();
      });

      searchInput.addEventListener('input', function() {
        clearTimeout(timer);
        var q = searchInput.value.trim();
        clearBtn.style.display = q ? 'block' : 'none';
        if (q.length < 2) { restoreOriginal(); return; }
        timer = setTimeout(function() { doSearch(q); }, 220);
      });

      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { searchInput.value = ''; clearBtn.click(); }
      });

      async function doSearch(q) {
        spinner.style.display = 'block';
        try {
          var res = await api('/projects/search?q=' + encodeURIComponent(q));
          spinner.style.display = 'none';
          if (!res.success) return;
          if (pagNav) pagNav.style.display = 'none';

          if (!res.results.length) {
            grid.innerHTML = '<div class="search-status"><i data-lucide="search-x" style="width:32px;height:32px;opacity:.4;margin-bottom:8px;display:block;margin-left:auto;margin-right:auto;"></i>No results for "' + esc(q) + '"</div>';
            countEl.textContent = '0 results';
            lucide.createIcons();
            return;
          }
          countEl.textContent = res.results.length + ' result' + (res.results.length !== 1 ? 's' : '');
          grid.innerHTML = res.results.map(function(r) {
            var firstTrans = '';
            var firstCode = '';
            if (r.trans_preview) { firstTrans = r.trans_preview; firstCode = r.lang_codes && r.lang_codes[0] ? r.lang_codes[0] : ''; }
            var langPills = (r.lang_codes || []).map(function(c) { return '<span class="card-lang-pill">' + esc(c) + '</span>'; }).join('');

            return '<div class="session-card" data-id="' + r.id + '" onclick="heroExpand(' + r.id + ',this)">'
              + '<div class="card-top">'
              + '<div class="card-title-row"><h3 class="card-title">' + hl(r.title, q) + '</h3>'
              + '<div class="card-actions" style="opacity:1;">'
              + '<button class="card-action-btn load-btn" onclick="event.stopPropagation();heroExpand(' + r.id + ',this.closest(\'.session-card\'))" title="Open"><i data-lucide="external-link" style="width:13px;height:13px;"></i></button>'
              + '<button class="card-action-btn del-btn" onclick="event.stopPropagation();deleteSession(' + r.id + ',this)" title="Delete"><i data-lucide="trash-2" style="width:13px;height:13px;"></i></button>'
              + '</div></div>'
              + '<p class="card-source">' + hl(trunc(r.preview, 120), q) + '</p>'
              + (firstTrans ? '<p class="card-translation"><span class="card-trans-label">' + esc(firstCode.toUpperCase()) + '</span>' + hl(trunc(firstTrans, 90), q) + '</p>' : '')
              + '</div>'
              + '<div class="card-bottom">'
              + '<div class="card-meta">'
              + '<span class="card-meta-item">' + esc(r.source_lang) + '</span>'
              + '<span class="card-meta-dot">·</span>'
              + '<span class="card-meta-item">' + r.word_count + 'w</span>'
              + '<span class="card-meta-dot">·</span>'
              + '<span class="card-meta-item">' + esc(r.time_ago) + '</span>'
              + '</div>'
              + '<div class="card-langs">' + langPills + '</div>'
              + '</div></div>';
          }).join('');
          lucide.createIcons();
        } catch (e) { spinner.style.display = 'none'; }
      }

      // Hero Expand - 5-Phase Content Reveal
      function wait(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

      function typewriter(el, text, speed) {
        return new Promise(function(resolve) {
          var i = 0;
          var display = text.substring(0, 120);
          function tick() {
            if (i <= display.length) {
              el.textContent = display.substring(0, i);
              i++;
              setTimeout(tick, speed);
            } else {
              el.classList.add('done');
              resolve();
            }
          }
          tick();
        });
      }

      window.heroExpand = async function(sessionId, cardEl) {
        if (!cardEl || cardEl.dataset.expanding) return;
        cardEl.dataset.expanding = '1';

        var rect = cardEl.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height / 2;
        overlay.style.setProperty('--hx', cx + 'px');
        overlay.style.setProperty('--hy', cy + 'px');

        grid.classList.add('is-scattering');
        cardEl.classList.add('is-hero');
        if (pagNav) pagNav.style.opacity = '0';

        var fetchPromise = api('/projects/session/' + sessionId).catch(function(e) { return { error: e }; });

        var clone = document.createElement('div');
        clone.className = 'hero-clone';
        clone.style.cssText = 'top:' + rect.top + 'px;left:' + rect.left + 'px;width:' + rect.width + 'px;height:' + rect.height + 'px;background:' + getComputedStyle(cardEl).background + ';';

        clone.innerHTML = '<div class="hero-reveal">'
          + '<div class="hero-source-label">Source Text</div>'
          + '<div class="hero-source-text" id="hero-src"></div>'
          + '<div class="hero-divider"></div>'
          + '<div class="hero-trans-label" id="hero-tl"></div>'
          + '<div class="hero-trans-text" id="hero-tt"></div>'
          + '<div class="hero-pills" id="hero-pills"></div>'
          + '<div class="hero-bottom">'
          + '  <div class="hero-progress-track"><div class="hero-progress-fill"></div></div>'
          + '  <div class="hero-status-label" id="hero-status">Preparing workspace…</div>'
          + '</div>'
          + '</div>';
        document.body.appendChild(clone);

        overlay.classList.add('is-active');

        // Phase 1: Expand
        await wait(60);
        clone.classList.add('is-expanding');
        await wait(650);

        var res = await fetchPromise;
        if (res.error || !res.success || !res.session) {
          clone.classList.remove('is-expanding');
          overlay.classList.remove('is-active');
          grid.classList.remove('is-scattering');
          cardEl.classList.remove('is-hero');
          delete cardEl.dataset.expanding;
          if (pagNav) pagNav.style.opacity = '';
          await wait(400);
          clone.remove();
          Toast.error('Failed to load session.');
          return;
        }

        var session = res.session;
        var srcText = session.source_text || session.sourceText || '';
        var translations = session.translations || {};
        var langCodes = Object.keys(translations);
        var firstCode = langCodes[0] || '';
        var firstTrans = translations[firstCode] || '';

        // Phase 2: Typewriter
        clone.classList.add('phase-2');
        await wait(300);
        var srcEl = document.getElementById('hero-src');
        await typewriter(srcEl, srcText, 18);
        await wait(200);

        // Phase 3: Translation slide
        clone.classList.add('phase-3');
        var tlEl = document.getElementById('hero-tl');
        var ttEl = document.getElementById('hero-tt');
        if (firstCode) tlEl.textContent = firstCode.toUpperCase() + ' Translation';
        ttEl.textContent = firstTrans.substring(0, 120) + (firstTrans.length > 120 ? '…' : '');
        await wait(800);

        // Phase 4: Language pills
        clone.classList.add('phase-4');
        var pillsEl = document.getElementById('hero-pills');
        pillsEl.innerHTML = langCodes.map(function(c) { return '<span class="hero-pill">' + c.toUpperCase() + '</span>'; }).join('');
        await wait(500);

        // Phase 5: Progress + redirect
        clone.classList.add('phase-5');
        var statusEl = document.getElementById('hero-status');
        statusEl.textContent = 'Opening workspace…';
        await wait(1100);

        sessionStorage.setItem('loadSession', JSON.stringify(session));
        window.location.href = '/';
      };

      // Delete Session
      window.deleteSession = async function(id, btn) {
        ConfirmDelete.show('Delete Translation', 'This will permanently remove this saved translation.', async function() {
          try {
            await api('/projects/session/' + id + '/delete', { method: 'POST' });
            btn.closest('.session-card').remove();
            Toast.success('Deleted.');
          } catch (e) { Toast.error('Failed.'); }
        });
      };
    })();
  </script>
</body>
</html>
