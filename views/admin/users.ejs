<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <style>
    .admin-content {
      padding: 32px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .admin-title {
      font-size: 28px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 8px;
    }
    .admin-subtitle {
      color: #6b7280;
      font-size: 14px;
      margin-bottom: 24px;
    }
    .card {
      background: #141820;
      border: 1px solid rgba(212, 175, 55, 0.15);
      border-radius: 16px;
      padding: 24px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 12px 16px;
      text-align: left;
      border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }
    th {
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    td {
      font-size: 14px;
      color: #fff;
    }
    tr:hover td {
      background: rgba(212, 175, 55, 0.03);
    }
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    .badge-admin {
      background: rgba(212, 175, 55, 0.15);
      color: #d4af37;
    }
    .badge-user {
      background: rgba(59, 130, 246, 0.15);
      color: #3b82f6;
    }
    .mobile-menu-close {
      display: none;
      position: absolute;
      top: 24px;
      right: 24px;
      background: none;
      border: none;
      color: var(--gold-400);
      cursor: pointer;
      z-index: 2001;
    }
    @media (max-width: 768px) {
      .mobile-open .mobile-menu-close {
        display: block;
      }
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }
    .btn-sm {
      padding: 6px 12px;
      font-size: 12px;
    }
    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      border: 1px solid rgba(212, 175, 55, 0.2);
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
    }
    .btn-danger {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .btn-danger:hover {
      background: rgba(239, 68, 68, 0.15);
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
      color: #6b7280;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #d4af37;
    }
    .actions {
      display: flex;
      gap: 8px;
    }
    @media (max-width: 768px) {
      .admin-content { padding: 16px; }
      .admin-title {
        font-size: 22px;
      }
      .card {
        padding: 16px;
        overflow-x: auto;
      }
      table {
        min-width: 600px;
      }
      th, td {
        padding: 10px 12px;
        font-size: 13px;
      }
      .actions {
        flex-direction: column;
        gap: 6px;
      }
      .btn-sm {
        padding: 5px 10px;
        font-size: 11px;
      }
    }
    @media (max-width: 480px) {
      .admin-header {
        padding: 10px 12px;
      }
      .admin-nav a {
        padding: 5px 10px;
        font-size: 11px;
      }
      .admin-user-avatar {
        width: 32px;
        height: 32px;
      }
      .admin-title {
        font-size: 20px;
      }
      th, td {
        padding: 8px 10px;
        font-size: 12px;
      }
      .badge {
        padding: 3px 8px;
        font-size: 10px;
      }
    }
  </style>
</head>
<body class="dark-theme">
  <%- include('../partials/admin-header.ejs', { activePage: 'users', user: user }) %>

  <main class="admin-content">
    <h1 class="admin-title">Manage Users</h1>
    <p class="admin-subtitle">View and manage user accounts and permissions.</p>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td><strong><%= u.username %></strong></td>
            <td style="color:#9ca3af;"><%= u.email %></td>
            <td>
              <span class="badge <%= u.role === 'admin' ? 'badge-admin' : 'badge-user' %>">
                <%= u.role %>
              </span>
            </td>
            <td style="color:#6b7280;"><%= u.createdAt?.toLocaleDateString() || '-' %></td>
            <td class="actions">
              <% if (u._id.toString() !== user._id.toString()) { %>
                <% if (u.role === 'user') { %>
                <button class="btn btn-secondary btn-sm" onclick="makeAdmin('<%= u._id %>')">
                  <i data-lucide="shield" style="width:12px;height:12px;"></i> Make Admin
                </button>
                <% } else { %>
                <button class="btn btn-danger btn-sm" onclick="makeUser('<%= u._id %>')">
                  <i data-lucide="user" style="width:12px;height:12px;"></i> Make User
                </button>
                <% } %>
              <% } else { %>
                <span style="color:#6b7280;font-size:12px;">(You)</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <a href="/admin" class="back-link">
      <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back to Dashboard
    </a>
  </main>

  <script src="/js/app.js?v=2"></script>
  <script>
    lucide.createIcons();
    
    async function makeAdmin(id) {
      if (!confirm('Make this user an admin?')) return;
      try {
        const res = await fetch(`/admin/users/${id}/role`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: 'admin' })
        });
        const result = await res.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert(result.error);
        }
      } catch (err) {
        alert('Failed to update user role');
      }
    }
    
    async function makeUser(id) {
      if (!confirm('Remove admin privileges from this user?')) return;
      try {
        const res = await fetch(`/admin/users/${id}/role`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: 'user' })
        });
        const result = await res.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert(result.error);
        }
      } catch (err) {
        alert('Failed to update user role');
      }
    }
  </script>
</body>
</html>
