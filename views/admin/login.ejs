<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — ORBIS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #080a12;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .admin-login-container {
      width: 100%;
      max-width: 380px;
    }
    .admin-login-card {
      background: #141820;
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      animation: fadeInUp 0.5s ease-out;
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .admin-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(212, 175, 55, 0.1);
      border: 1px solid rgba(212, 175, 55, 0.3);
      color: #d4af37;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
    }
    .admin-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .admin-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 28px;
      font-weight: 700;
      color: #d4af37;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    .admin-logo-image {
      width: 36px;
      height: 36px;
      object-fit: contain;
      display: block;
    }
    .admin-subtitle {
      color: #6b7280;
      font-size: 13px;
      margin-top: 8px;
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #9ca3af;
      margin-bottom: 6px;
    }
    .form-input {
      width: 100%;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 10px;
      font-size: 15px;
      color: #fff;
      transition: all 0.2s;
      outline: none;
    }
    .form-input:focus {
      border-color: #d4af37;
      background: rgba(255, 255, 255, 0.05);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, #d4af37 0%, #b8960c 100%);
      color: #000;
      width: 100%;
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 20px -10px rgba(212, 175, 55, 0.4);
      background: linear-gradient(135deg, #e5c158 0%, #d4af37 100%);
    }
    .btn-primary:active {
      transform: translateY(0);
    }
    .btn-primary:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }
    .back-link {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 24px;
      color: #6b7280;
      font-size: 13px;
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #d4af37;
    }
    .toast {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 24px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 500;
      z-index: 1000;
      animation: slideUp 0.3s ease-out;
    }
    .toast-error {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    .toast-success {
      background: rgba(22, 163, 74, 0.1);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translate(-50%, 20px); }
      to { opacity: 1; transform: translate(-50%, 0); }
    }
    .error-msg {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #ef4444;
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 20px;
      text-align: center;
      display: none;
    }
    .error-msg.show {
      display: block;
    }
  </style>
</head>
<body>
  <div class="admin-login-container">
    <div class="admin-login-card">
      <div class="admin-header">
        <div class="admin-badge">
          <i data-lucide="shield" style="width:12px;height:12px;"></i> Admin Portal
        </div>
        <div class="admin-logo"><img src="/logo.png" alt="ORBIS logo" class="admin-logo-image"> ORBIS</div>
        <p class="admin-subtitle">Sign in to access the admin dashboard</p>
      </div>

      <div id="error-box" class="error-msg"></div>

      <form id="admin-login-form">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input type="text" class="form-input" id="username" name="username" placeholder="Enter admin username" autocomplete="username" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input type="password" class="form-input" id="password" name="password" placeholder="Enter password" autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="log-in" style="width:18px;height:18px;"></i> Sign In
        </button>
      </form>
    </div>

    <a href="/" class="back-link">
      <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back to ORBIS
    </a>
  </div>

  <script>
    lucide.createIcons();
    
    const errorBox = document.getElementById('error-box');
    
    function showError(message) {
      errorBox.textContent = message;
      errorBox.classList.add('show');
    }
    
    function hideError() {
      errorBox.classList.remove('show');
    }
    
    document.getElementById('admin-login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();
      
      const form = e.target;
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader-2" style="width:18px;height:18px;animation:spin 1s linear infinite;"></i> Signing in...';
      lucide.createIcons();
      
      try {
        const res = await fetch('/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            username: form.username.value,
            password: form.password.value
          })
        });
        
        const result = await res.json();
        
        if (result.success) {
          // Check if user is admin
          if (result.user && result.user.role === 'admin') {
            window.location.reload();
          } else {
            showError('Access denied. Admin privileges required.');
            btn.disabled = false;
            btn.innerHTML = originalText;
            lucide.createIcons();
          }
        } else {
          showError(result.error || 'Invalid credentials');
          btn.disabled = false;
          btn.innerHTML = originalText;
          lucide.createIcons();
        }
      } catch (err) {
        showError('Login failed. Please try again.');
        btn.disabled = false;
        btn.innerHTML = originalText;
        lucide.createIcons();
      }
    });
  </script>
</body>
</html>
